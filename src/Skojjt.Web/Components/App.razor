<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Skojjt.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <title>Skojjt - Närvarosystem för scouter</title>
</head>

<body>
    <Routes />
    
    <div id="components-reconnect-modal" class="components-reconnect-hide">
        <div class="reconnect-overlay"></div>
        <div class="reconnect-dialog">
            <div class="reconnect-content show-reconnecting">
                <div class="reconnect-icon">⟳</div>
                <h4>Ansluter till servern...</h4>
                <p>Vänta medan anslutningen återupprättas.</p>
            </div>
            <div class="reconnect-content show-failed">
                <div class="reconnect-icon">✕</div>
                <h4>Kunde inte återansluta</h4>
                <p>Det gick inte att återupprätta anslutningen till servern.</p>
                <button onclick="location.reload()">Ladda om sidan</button>
            </div>
            <div class="reconnect-content show-rejected">
                <div class="reconnect-icon">✕</div>
                <h4>Sessionen kunde inte återupptas</h4>
                <p>Servern kunde inte återuppta sessionen. Ladda om sidan för att fortsätta.</p>
                <button onclick="location.reload()">Ladda om sidan</button>
            </div>
        </div>
    </div>
    
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="js/export.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
