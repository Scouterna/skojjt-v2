<!DOCTYPE html>
<html lang="sv">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Skojjt.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <title>Skojjt - Närvarosystem för scouter</title>
    <script>
        try {
            if (localStorage.getItem('darkMode') === 'True') {
                document.documentElement.classList.add('dark-preload');
            }
        } catch (e) { }
    </script>
    <style>
        .dark-preload,
        .dark-preload body {
            background-color: #0F1214 !important;
            color: #ECEFF1 !important;
        }
        .dark-preload .mud-appbar {
            background-color: #141820 !important;
            color: #ECEFF1 !important;
        }
        .dark-preload .mud-drawer {
            background-color: #1A1F26 !important;
            color: #ECEFF1 !important;
        }
        .dark-preload .mud-main-content,
        .dark-preload main,
        .dark-preload section {
            background-color: #0F1214 !important;
            color: #ECEFF1 !important;
        }
        .dark-preload .mud-paper,
        .dark-preload .mud-card,
        .dark-preload .mud-table {
            background-color: #1E2329 !important;
            color: #ECEFF1 !important;
            border-color: #37414B !important;
        }
        .dark-preload .mud-container {
            color: #ECEFF1 !important;
        }
        .dark-preload .mud-breadcrumbs,
        .dark-preload .mud-chip,
        .dark-preload .mud-alert,
        .dark-preload .mud-expansion-panel {
            background-color: #1E2329 !important;
            color: #ECEFF1 !important;
        }
        .dark-preload .mud-nav-link,
        .dark-preload .mud-button,
        .dark-preload a {
            color: #ECEFF1 !important;
        }
        .dark-preload .mud-input,
        .dark-preload .mud-input-control {
            color: #ECEFF1 !important;
        }
    </style>
</head>

<body>
    <Routes />
    
    <div id="components-reconnect-modal" class="components-reconnect-hide">
        <div class="reconnect-overlay"></div>
        <div class="reconnect-dialog">
            <div class="reconnect-content show-reconnecting">
                <div class="reconnect-icon">⟳</div>
                <h4>Ansluter till servern...</h4>
                <p>Vänta medan anslutningen återupprättas.</p>
            </div>
            <div class="reconnect-content show-failed">
                <div class="reconnect-icon">✕</div>
                <h4>Kunde inte återansluta</h4>
                <p>Det gick inte att återupprätta anslutningen till servern.</p>
                <button onclick="location.reload()">Ladda om sidan</button>
            </div>
            <div class="reconnect-content show-rejected">
                <div class="reconnect-icon">⟳</div>
                <h4>Sessionen kunde inte återupptas</h4>
                <p>Servern har uppdaterats. Sidan laddas om automatiskt...</p>
            </div>
        </div>
    </div>
    
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="js/export.js"></script>
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        // Configure Blazor Server reconnection with exponential backoff.
        // Default behavior only retries ~8 times over ~40 seconds.
        // This configuration retries for several minutes with increasing delays,
        // giving mobile/Wi-Fi users time to recover from brief network drops.
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 30,
                    retryIntervalMilliseconds: (previousAttempts, maxRetries) => {
                        // Exponential backoff: 1s, 2s, 4s, 8s... capped at 30s
                        const baseDelay = 1000;
                        const maxDelay = 30000;
                        const delay = Math.min(baseDelay * Math.pow(2, previousAttempts), maxDelay);
                        return delay;
                    },
                    dialogId: 'components-reconnect-modal'
                }
            }
        });

        // When the circuit is rejected (server restarted / deployed), auto-reload
        // after a short delay instead of showing a dead-end dialog.
        new MutationObserver((mutations) => {
            for (const m of mutations) {
                if (m.target.classList.contains('components-reconnect-rejected')) {
                    setTimeout(() => location.reload(), 2000);
                    break;
                }
            }
        }).observe(document.getElementById('components-reconnect-modal'), {
            attributes: true, attributeFilter: ['class']
        });
    </script>
</body>

</html>
