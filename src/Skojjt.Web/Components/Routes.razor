@rendermode InteractiveServer
@using Microsoft.JSInterop
@using Skojjt.Web.Services
@using Skojjt.Web.Theme
@inject ThemeService ThemeService
@implements IDisposable

<MudThemeProvider Theme="SkojjtTheme.Theme" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@inject IJSRuntime JS

@code {
    private bool _isDarkMode;
    private bool _disposed;
    private bool _removePreloadOnNextRender;

    protected override void OnInitialized()
    {
        _isDarkMode = ThemeService.IsDarkMode;
        ThemeService.OnThemeChanged += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "darkMode");
                if (stored is not null && bool.TryParse(stored, out var darkMode) && darkMode != _isDarkMode)
                {
                    // Setting IsDarkMode triggers OnThemeChanged -> StateHasChanged -> another render.
                    // Defer class removal to that next render so MudBlazor's dark styles are applied first.
                    _removePreloadOnNextRender = true;
                    ThemeService.IsDarkMode = darkMode;
                }
                else
                {
                    await RemovePreloadClass();
                }
            }
            catch (JSDisconnectedException) { }
            catch (InvalidOperationException) { }
        }
        else if (_removePreloadOnNextRender)
        {
            _removePreloadOnNextRender = false;
            try
            {
                await RemovePreloadClass();
            }
            catch (JSDisconnectedException) { }
            catch (InvalidOperationException) { }
        }
    }

    private ValueTask RemovePreloadClass() =>
        JS.InvokeVoidAsync("eval", "document.documentElement.classList.remove('dark-preload')");

    private async void OnThemeChanged()
    {
        if (_disposed) return;

        _isDarkMode = ThemeService.IsDarkMode;

        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (JSDisconnectedException) { /* Circuit disconnected */ }
        catch (ObjectDisposedException) { /* Component disposed */ }
        catch (TaskCanceledException) { /* Operation canceled */ }
        catch (InvalidOperationException) { /* Circuit may be disposed */ }
    }

    public void Dispose()
    {
        _disposed = true;
        ThemeService.OnThemeChanged -= OnThemeChanged;
    }
}
