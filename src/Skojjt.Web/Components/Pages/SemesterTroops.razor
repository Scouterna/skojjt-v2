@page "/sk/{ScoutGroupId:int}/t/{SemesterId:int}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.Extensions.Options
@using Skojjt.Core.Authentication
@using Skojjt.Core.Entities
@using Skojjt.Core.Interfaces
@using Skojjt.Core.Services
@using Skojjt.Infrastructure.Scoutnet
@attribute [Authorize]
@rendermode InteractiveServer
@inject IOptions<ScoutnetOptions> ScoutnetOptions
@inject IScoutGroupRepository ScoutGroupRepository
@inject IBadgeService BadgeService
@inject ISemesterRepository SemesterRepository
@inject ITroopRepository TroopRepository
@inject ICurrentUserService CurrentUserService
@inject IMembershipSyncService MembershipSyncService
@inject ICampService CampService
@inject IScoutnetApiClient ScoutnetApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Avdelningar - @(_semester?.DisplayName ?? "Termin") - Skojjt</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!_hasAccess)
    {
        <MudAlert Severity="Severity.Error">
            Du har inte behörighet att visa denna scoutkår.
        </MudAlert>
    }
    else if (_scoutGroup == null || _semester == null)
    {
        <MudAlert Severity="Severity.Error">Scoutkåren eller terminen kunde inte hittas.</MudAlert>
    }
    else
    {
        <div class="d-flex flex-wrap align-center justify-space-between mb-4">
            <div>
                <MudText Typo="Typo.h4">@_scoutGroup.Name</MudText>
                <MudText Typo="Typo.h6" Color="Color.Secondary">@_semester.DisplayName</MudText>
            </div>
            
            @* Semester navigation *@
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                @if (_previousSemester != null)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.ChevronLeft"
                               Href="@($"/sk/{ScoutGroupId}/t/{_previousSemester.Id}")">
                        @_previousSemester.DisplayName
                    </MudButton>
                }
                @if (_nextSemester != null)
                {
                    <MudButton EndIcon="@Icons.Material.Filled.ChevronRight"
                               Href="@($"/sk/{ScoutGroupId}/t/{_nextSemester.Id}")">
                        @_nextSemester.DisplayName
                    </MudButton>
                }
            </MudButtonGroup>
        </div>

        @if (_troops.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                Inga avdelningar för denna termin.
            </MudAlert>
        }
        else
        {
            <MudGrid>
                @foreach (var troop in _troops)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudLink Href="@(Invariant($"/sk/{ScoutGroupId}/t/{SemesterId}/{troop.ScoutnetId}"))" Underline="Underline.None" Class="d-block">
                            <MudCard Elevation="2" Class="hover-card">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <div class="d-flex align-center gap-2">
                                            @if (troop.IsCamp)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Forest" Size="Size.Small" Color="Color.Tertiary" />
                                            }
                                            <MudText Typo="Typo.h6">@troop.Name</MudText>
                                            @if (troop.IsLocked)
                                            {
                                                <MudTooltip Text="Avdelningen är låst för redigering">
                                                    <MudIcon Icon="@Icons.Material.Filled.Lock" 
                                                             Size="Size.Small"
                                                             Style="color: #b5a642;" />
                                                </MudTooltip>
                                            }
                                        </div>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default" />
                                    </CardHeaderActions>
                                </MudCardHeader>
                                <MudCardContent>
                                    @if (troop.IsCamp && troop.CampStartDate.HasValue && troop.CampEndDate.HasValue)
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                            @troop.CampStartDate.Value.ToString("d MMM") – @troop.CampEndDate.Value.ToString("d MMM yyyy")
                                        </MudText>
                                    }
                                    <div class="d-flex gap-4">
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(troop.IsCamp ? "Deltagare" : "Medlemmar")</MudText>
                                            <MudText Typo="Typo.h6">@troop.TroopPersons.Count</MudText>
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(troop.IsCamp ? "Lägerdagar" : "Möten")</MudText>
                                            <MudText Typo="Typo.h6">@troop.Meetings.Count</MudText>
                                        </div>
                                    </div>

                                    @if (_troopBadges.TryGetValue(troop.Id, out var badges) && badges.Count > 0)
                                    {
                                        <MudDivider Class="my-2" />
                                        <div class="d-flex flex-wrap gap-1">
                                            @foreach (var badge in badges)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary"
                                                         Icon="@Icons.Material.Filled.EmojiEvents">
                                                    @badge.Name
                                                </MudChip>
                                            }
                                        </div>
                                    }

                                    @if (troop.TroopPersons.Count > 0)
                                    {
                                        <MudDivider Class="my-2" />
                                        <div class="d-flex flex-wrap gap-1">
                                            @{
                                                var leaders = troop.TroopPersons.Where(tp => tp.IsLeader).Take(4).ToList();
                                            }
                                            @foreach (var leader in leaders)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                                                    @leader.Person?.FirstName
                                                </MudChip>
                                            }
                                            @if (troop.TroopPersons.Count(tp => tp.IsLeader) > 4)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                                    +@(troop.TroopPersons.Count(tp => tp.IsLeader) - 4)
                                                </MudChip>
                                            }
                                        </div>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudLink>
                    </MudItem>
                }
            </MudGrid>
        }

        @* Quick actions *@
        <MudDivider Class="my-6" />
        <MudExpansionPanels>
            @if (_isMemberRegistrar)
            {
                <MudExpansionPanel Text="Läger" Icon="@Icons.Material.Filled.Forest">
                    <MudText Typo="Typo.body2" Class="mb-3">
                        Importera deltagare från ett Scoutnet-projekt för att skapa ett läger.
                    </MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudDownload"
                               OnClick="OpenImportCampDialog">
                        Importera från Scoutnet
                    </MudButton>
                </MudExpansionPanel>
            }
            @if (_canSync)
            {
                <MudExpansionPanel Text="Scoutnet-synk" Icon="@Icons.Material.Filled.Sync">
                    <MudText Typo="Typo.body2" Class="mb-3">
                        Synka avdelnings- och patrulltillhörighet från Skojjt till Scoutnet.
                        Ändringar du gjort i Skojjt (t.ex. flyttat en medlem till annan avdelning eller patrull) kan skickas tillbaka till Scoutnet.
                    </MudText>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Sync"
                               OnClick="PreviewMembershipSync"
                               Disabled="_syncLoading">
                        @if (_syncLoading)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Förhandsgranska ändringar
                    </MudButton>
                </MudExpansionPanel>
            }
            <MudExpansionPanel Text="Rapporter & Export" Icon="@Icons.Material.Filled.Assessment">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Närvarorapporter per avdelning finns i respektive avdelnings vy.</MudText>
                <MudGrid>
                    <MudItem xs="12" sm="6" md="4">
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Description"
                                   OnClick="@(() => OpenGothenburgCsvDialog())">
                            Aktivitetsbidrag CSV (Göteborg)
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Payments"
                                   OnClick="@(() => OpenLagerbidragDialog("gbg"))">
                            Lägerbidrag (Göteborg)
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Payments"
                                   OnClick="@(() => OpenLagerbidragDialog("sthlm"))">
                            Lägerbidrag (Stockholm)
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Summarize"
                                   Href="@($"/sk/{ScoutGroupId}/summary/{SemesterId}")">
                            Föreningsredovisning
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
</MudContainer>

@* Lagerbidrag Dialog *@
<MudDialog @bind-Visible="_showLagerbidragDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Payments" Class="mr-2" />
            Lägerbidrag @(_lagerbidragRegion == "gbg" ? "Göteborg" : "Stockholm")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_lagerbidragForm">
            <MudSelect T="int?" @bind-Value="_selectedTroopId" Label="Avdelning" Variant="Variant.Outlined" Required="true">
                <MudSelectItem T="int?" Value="null">Alla avdelningar</MudSelectItem>
                @foreach (var troop in _troops)
                {
                    <MudSelectItem T="int?" Value="@troop.Id">@troop.Name</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_lagerbidragContact" Label="Kontaktperson" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="_lagerbidragContactEmail" Label="E-post" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_lagerbidragContactPhone" Label="Telefon" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="_lagerbidragSite" Label="Lägerplats" Variant="Variant.Outlined" Required="true" />
            <MudDatePicker @bind-Date="_lagerbidragFromDate" Label="Från datum" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Required="true" />
            <MudDatePicker @bind-Date="_lagerbidragToDate" Label="Till datum" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Required="true" />
            <MudCheckBox @bind-Value="_lagerbidragDuringBreak" Label="Läger under lov" Color="Color.Primary" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showLagerbidragDialog = false)">Avbryt</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="GenerateLagerbidrag">Generera rapport</MudButton>
    </DialogActions>
</MudDialog>

@* Gothenburg CSV Dialog *@
<MudDialog @bind-Visible="_showGbgCsvDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
            Aktivitetsbidrag CSV (Göteborg)
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
            Exporterar en CSV-fil med alla medlemmar som uppfyller närvarokravet för aktivitetsbidrag.
            Filen kan laddas upp till Göteborgs kommuns portal.
        </MudAlert>
        <MudRadioGroup @bind-Value="_gbgCsvUseSemesterMin">
            <MudRadio Value="false" Color="Color.Primary">
                <div>
                    <MudText>Årsvis (@_semester?.Year)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Minst @(_scoutGroup?.AttendanceMinYear ?? 10) möten under hela året
                    </MudText>
                </div>
            </MudRadio>
            <MudRadio Value="true" Color="Color.Primary">
                <div>
                    <MudText>Terminsvis (@_semester?.DisplayName)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Minst @(_scoutGroup?.AttendanceMinSemester ?? 5) möten under terminen
                    </MudText>
                </div>
            </MudRadio>
        </MudRadioGroup>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4">
            Närvarogränser kan ändras i <MudLink Href="@($"/sk/{ScoutGroupId}/settings")">kårinställningar</MudLink>.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showGbgCsvDialog = false)">Avbryt</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="DownloadGothenburgCsv">Ladda ner CSV</MudButton>
    </DialogActions>
</MudDialog>

@* Scoutnet Membership Sync Dialog *@
<MudDialog @bind-Visible="_showSyncDialog" Options="_syncDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Sync" Class="mr-2" />
            Synka med Scoutnet
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_syncPreview == null)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_syncPreview.TotalChanges == 0)
        {
            <MudAlert Severity="Severity.Success" Dense="true">
                Inga skillnader hittades — Skojjt och Scoutnet är synkade.
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                @_syncPreview.TotalChanges ändring(ar) hittades som kan skickas till Scoutnet.
            </MudAlert>

            @if (_syncPreview.TroopChanges.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Small" Class="mr-1" />
                    Avdelningsbyten (@_syncPreview.TroopChanges.Count)
                </MudText>
                <MudSimpleTable Dense="true" Hover="true" Class="mb-4">
                    <thead>
                        <tr>
                            <th>Medlem</th>
                            <th>I Scoutnet</th>
                            <th></th>
                            <th>I Skojjt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var change in _syncPreview.TroopChanges)
                        {
                            <tr>
                                <td>@change.MemberName</td>
                                <td>@change.CurrentTroopName</td>
                                <td><MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" /></td>
                                <td><strong>@change.NewTroopName</strong></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }

            @if (_syncPreview.PatrolChanges.Count > 0)
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Small" Class="mr-1" />
                    Patrullbyten (@_syncPreview.PatrolChanges.Count)
                </MudText>
                <MudSimpleTable Dense="true" Hover="true" Class="mb-4">
                    <thead>
                        <tr>
                            <th>Medlem</th>
                            <th>I Scoutnet</th>
                            <th></th>
                            <th>I Skojjt</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var change in _syncPreview.PatrolChanges)
                        {
                            <tr>
                                <td>@change.MemberName</td>
                                <td>@change.CurrentPatrolName</td>
                                <td><MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" /></td>
                                <td><strong>@change.NewPatrolName</strong></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }

            @if (_syncPreview.UnmappedPatrolWarnings.Count > 0)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    <MudText Typo="Typo.body2">Följande patrulländringar kan inte synkas (saknar Scoutnet-ID):</MudText>
                    <MudList T="string" Dense="true">
                        @foreach (var warning in _syncPreview.UnmappedPatrolWarnings)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Warning">@warning</MudListItem>
                        }
                    </MudList>
                </MudAlert>
            }
        }

        @if (_syncResult != null)
        {
            @if (_syncResult.Success)
            {
                <MudAlert Severity="Severity.Success" Class="mt-3">
                    @_syncResult.UpdatedCount medlem(mar) uppdaterade i Scoutnet.
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">
                    @_syncResult.ErrorMessage
                </MudAlert>
                @if (_syncResult.Details.Count > 0)
                {
                    <MudPaper Class="mt-2 pa-3" Outlined="true" Style="max-height: 300px; overflow-y: auto; user-select: text;">
                        @foreach (var detail in _syncResult.Details)
                        {
                            <MudText Typo="Typo.body2" Style="user-select: text;">@detail</MudText>
                        }
                    </MudPaper>
                }
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showSyncDialog = false)">Stäng</MudButton>
        @if (_syncPreview?.TotalChanges > 0 && _syncResult == null)
        {
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.CloudUpload"
                       OnClick="PushMembershipSync"
                       Disabled="_syncPushing">
                @if (_syncPushing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Skicka till Scoutnet
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@* Import Camp from Scoutnet Dialog *@
<MudDialog @bind-Visible="_showImportCampDialog" Options="_syncDialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Class="mr-2" />
            Importera läger från Scoutnet
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_campImportResult != null)
        {
            @if (_campImportResult.Success)
            {
                <MudAlert Severity="Severity.Success" Class="mb-3">
                    Läger skapat med @(_campImportResult.CampResult?.MeetingsCreated ?? 0) lägerdagar.
                    @_campImportResult.ParticipantsImported deltagare importerade.
                </MudAlert>
                @if (_campImportResult.ParticipantsSkipped > 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        @_campImportResult.ParticipantsSkipped deltagare kunde inte importeras (saknas i databasen).
                        Kör Scoutnet-import först för att lägga till dem.
                    </MudAlert>
                    <MudPaper Class="mt-2 pa-3" Outlined="true" Style="max-height: 200px; overflow-y: auto;">
                        @foreach (var name in _campImportResult.SkippedNames)
                        {
                            <MudText Typo="Typo.body2">@name</MudText>
                        }
                    </MudPaper>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Error">
                    @_campImportResult.ErrorMessage
                </MudAlert>
            }
        }
        else if (_importPreviewParticipants == null)
        {
            @* Step 1: Enter project ID + API keys (with optional project picker) *@
            @if (_projectsLoading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">Hämtar arrangemang från Scoutnet...</MudText>
            }
            else if (_groupProjects is { Count: > 0 })
            {
                <MudText Typo="Typo.subtitle2" Class="mb-2">Välj arrangemang</MudText>
                <MudPaper Outlined="true" Class="mb-4" Style="max-height: 200px; overflow-y: auto;">
                    <MudList T="ScoutnetGroupProject" Dense="true">
                        @foreach (var project in _groupProjects)
                        {
                            <MudListItem T="ScoutnetGroupProject" OnClick="@(() => SelectProject(project))"
                                         Icon="@(project.Id.HasValue && project.Id.Value == _importProjectId ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Event)">
                                <div>
                                    <MudText Typo="Typo.body1">@project.Name</MudText>
                                    @if (project.Starts.HasValue && project.Ends.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @project.Starts.Value.ToString("d MMM yyyy") – @project.Ends.Value.ToString("d MMM yyyy")
                                        </MudText>
                                    }
                                    @if (!project.Id.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Warning">
                                            Projekt-ID saknas — ange det manuellt nedan
                                        </MudText>
                                    }
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
                <MudDivider Class="mb-3" />
            }
            else
            {
                @if (_projectsError != null)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        @_projectsError
                    </MudAlert>
                }
                else if (string.IsNullOrWhiteSpace(_scoutGroup?.ApiKeyGroupProjects))
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        <b>Tips:</b> Konfigurera API-nyckeln "Kårens arrangemang" i
                        <MudLink Href="@($"/sk/{ScoutGroupId}/settings")" Target="_blank">kårinställningar</MudLink>
                        för att kunna välja arrangemang från en lista.
                    </MudAlert>
                }
            }

            <MudText Typo="Typo.body2" Class="mb-3">
                Ange Scoutnet projekt-ID och API-nycklar. Du hittar dessa på projektets API-sida i Scoutnet.
                Se <MudLink Href="@($"{ScoutnetOptions.Value.BaseUrl}/organisation/group/home/{ScoutGroupId}#viewgroup_tabmenu_tab_activities_pane")" Target="_blank">kårens arrangemang i Scoutnet</MudLink>.
            </MudText>
            <MudForm @ref="_importCampForm">
                <MudNumericField @bind-Value="_importProjectId" Label="Scoutnet projekt-ID" Variant="Variant.Outlined" Required="true" Min="1"
                                 HelperText="Projekt-ID:t syns i URL:en, t.ex. /activities/view/1190 → 1190" />
                <MudTextField @bind-Value="_importApiKey" Label="API-nyckel (get/participants)" Variant="Variant.Outlined" Required="true"
                              InputType="InputType.Password"
                              HelperText="&quot;Get a list of members who are registered on the project&quot;" />
                <MudTextField @bind-Value="_importCheckinApiKey" Label="API-nyckel (checkin)" Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              HelperText="Valfritt — synka närvarostatus tillbaka till Scoutnet" />
            </MudForm>
        }
        else
        {
            @* Step 2: Preview participants + fill in camp details *@
            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                @_importPreviewParticipants.Count deltagare hittade i Scoutnet-projektet.
            </MudAlert>
            <MudPaper Class="pa-3 mb-3" Outlined="true" Style="max-height: 150px; overflow-y: auto;">
                @foreach (var p in _importPreviewParticipants)
                {
                    <MudText Typo="Typo.body2">
                        @p.FullName
                        @if (p.Cancelled)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="ml-1">Avbokad</MudChip>
                        }
                        else if (!p.ExistsInDatabase)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="ml-1">Saknas i databasen</MudChip>
                        }
                    </MudText>
                }
            </MudPaper>
            <MudForm @ref="_importCampForm">
                <MudTextField @bind-Value="_campName" Label="Lägernamn" Variant="Variant.Outlined" Required="true" MaxLength="50" />
                <MudTextField @bind-Value="_campLocation" Label="Plats" Variant="Variant.Outlined" Required="true" MaxLength="100" />
                <MudDatePicker @bind-Date="_campStartDate" Label="Startdatum" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Required="true" />
                <MudDatePicker @bind-Date="_campEndDate" Label="Slutdatum" DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" Required="true" />
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        @if (_campImportResult != null)
        {
            <MudButton OnClick="@(() => { _showImportCampDialog = false; _campImportResult = null; })">Stäng</MudButton>
        }
        else if (_importPreviewParticipants == null)
        {
            <MudButton OnClick="@(() => _showImportCampDialog = false)">Avbryt</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="FetchImportPreview" Disabled="_campCreating">
                @if (_campCreating)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Hämta deltagare
            </MudButton>
        }
        else
        {
            <MudButton OnClick="@(() => { _importPreviewParticipants = null; })">Tillbaka</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                       OnClick="ImportCampFromScoutnet" Disabled="_campCreating">
                @if (_campCreating)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Importera
            </MudButton>
        }
    </DialogActions>
</MudDialog>

<style>
    .hover-card {
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .hover-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    }
</style>

@code {
    [Parameter]
    public int ScoutGroupId { get; set; }
    
    [Parameter]
    public int SemesterId { get; set; }

    private ScoutGroup? _scoutGroup;
    private Semester? _semester;
    private Semester? _previousSemester;
    private Semester? _nextSemester;
    private List<Troop> _troops = new();
    private Dictionary<int, IReadOnlyList<Badge>> _troopBadges = new();
    private bool _loading = true;
    private bool _hasAccess = false;
    private bool _initialized;
    private int _lastLoadedScoutGroupId;
    private int _lastLoadedSemesterId;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Lagerbidrag dialog state
    private bool _showLagerbidragDialog;
    private string _lagerbidragRegion = "gbg";
    private int? _selectedTroopId;
    private string _lagerbidragContact = "";
    private string _lagerbidragContactEmail = "";
    private string _lagerbidragContactPhone = "";
    private string _lagerbidragSite = "";
    private DateTime? _lagerbidragFromDate;
    private DateTime? _lagerbidragToDate;
    private bool _lagerbidragDuringBreak;
    private MudForm? _lagerbidragForm;
    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    // Gothenburg CSV dialog state
    private bool _showGbgCsvDialog;
    private bool _gbgCsvUseSemesterMin = false;

    // Membership sync state
    private bool _isMemberRegistrar;
    private bool _canSync;
    private bool _showSyncDialog;
    private bool _syncLoading;
    private bool _syncPushing;
    private MembershipSyncPreview? _syncPreview;
    private MembershipSyncResult? _syncResult;
    private DialogOptions _syncDialogOptions = new() { MaxWidth = MaxWidth.Medium, FullWidth = true };

    // Camp creation state
    private bool _showImportCampDialog;
    private bool _campCreating;
    private MudForm? _importCampForm;
    private string _campName = string.Empty;
    private string _campLocation = string.Empty;
    private DateTime? _campStartDate;
    private DateTime? _campEndDate;
    private int _importProjectId;
    private string _importApiKey = string.Empty;
    private string _importCheckinApiKey = string.Empty;
    private List<CampParticipantPreview>? _importPreviewParticipants;
    private CampImportResult? _campImportResult;
    private List<ScoutnetGroupProject>? _groupProjects;
    private bool _projectsLoading;
    private string? _projectsError;

    protected override async Task OnInitializedAsync()
    {
        _lastLoadedScoutGroupId = ScoutGroupId;
        _lastLoadedSemesterId = SemesterId;
        
        await LoadData();
        
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Skip if not initialized yet (OnInitializedAsync handles first load)
        if (!_initialized) return;
        
        // Only reload if parameters actually changed
        if (_lastLoadedScoutGroupId != ScoutGroupId || _lastLoadedSemesterId != SemesterId)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        
        // Track what we're loading
        _lastLoadedScoutGroupId = ScoutGroupId;
        _lastLoadedSemesterId = SemesterId;
        
        try
        {
            // Check if user has access to this scout group
            _hasAccess = CurrentUserService.HasGroupAccess(ScoutGroupId);
            _isMemberRegistrar = CurrentUserService.IsMemberRegistrar(ScoutGroupId);

            if (!_hasAccess)
            {
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Scoutkårer", href: "/sk"),
                    new BreadcrumbItem("Ingen behörighet", href: null, disabled: true)
                };
                return;
            }

            _scoutGroup = await ScoutGroupRepository.GetByIdAsync(ScoutGroupId);
            _semester = await SemesterRepository.GetByIdAsync(SemesterId);

            // Sync is only available for the current semester and when the API key is configured
            _canSync = _isMemberRegistrar
                       && _semester != null
                       && _semester.Id == Semester.GetCurrentSemester().Id
                       && !string.IsNullOrWhiteSpace(_scoutGroup?.ApiKeyUpdateMembership);
            
            if (_scoutGroup != null && _semester != null)
            {
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Scoutkårer", href: "/sk"),
                    new BreadcrumbItem(_scoutGroup.Name, href: $"/sk/{ScoutGroupId}"),
                    new BreadcrumbItem(_semester.DisplayName, href: null, disabled: true)
                };

                // Load troops with members - use a method that loads all data in one query
                var allTroops = await TroopRepository.GetByScoutGroupAndSemesterWithMembersAsync(ScoutGroupId, SemesterId);
                _troops = allTroops
                    .Where(t => CurrentUserService.HasTroopAccess(ScoutGroupId, t.ScoutnetId))
                    .OrderBy(t => t.TroopType)
                    .ThenBy(t => t.Name)
                    .ToList();

                // Load badges for each troop
                _troopBadges.Clear();
                foreach (var troop in _troops)
                {
                    _troopBadges[troop.Id] = await BadgeService.GetTroopBadgesAsync(troop.Id);
                }

                // Load available semesters for navigation
                var allSemesters = await SemesterRepository.GetByScoutGroupAsync(ScoutGroupId);
                var semesterList = allSemesters.OrderBy(s => s.Id).ToList();
                var currentIndex = semesterList.FindIndex(s => s.Id == SemesterId);
                
                _previousSemester = currentIndex > 0 ? semesterList[currentIndex - 1] : null;
                _nextSemester = currentIndex >= 0 && currentIndex < semesterList.Count - 1 
                    ? semesterList[currentIndex + 1] 
                    : null;
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenLagerbidragDialog(string region)
    {
        _lagerbidragRegion = region;
        _selectedTroopId = null;
        _lagerbidragContact = _scoutGroup?.Signatory ?? "";
        _lagerbidragContactEmail = _scoutGroup?.SignatoryEmail ?? "";
        _lagerbidragContactPhone = _scoutGroup?.SignatoryPhone ?? "";
        _lagerbidragSite = _scoutGroup?.DefaultCampLocation ?? "";
        _lagerbidragFromDate = null;
        _lagerbidragToDate = null;
        _lagerbidragDuringBreak = false;
        _showLagerbidragDialog = true;
    }

    private void GenerateLagerbidrag()
    {
        if (_lagerbidragForm != null && _lagerbidragFromDate.HasValue && _lagerbidragToDate.HasValue)
        {
            // Build the URL with all required parameters
            var url = $"/reports/lagerbidrag-{_lagerbidragRegion}?" +
                      $"scoutGroupId={ScoutGroupId}" +
                      $"&semesterId={SemesterId}" +
                      (_selectedTroopId.HasValue ? $"&troopId={_selectedTroopId.Value}" : "") +
                      $"&contact={Uri.EscapeDataString(_lagerbidragContact)}" +
                      $"&contactEmail={Uri.EscapeDataString(_lagerbidragContactEmail)}" +
                      $"&contactPhone={Uri.EscapeDataString(_lagerbidragContactPhone)}" +
                      $"&site={Uri.EscapeDataString(_lagerbidragSite)}" +
                      $"&fromDate={_lagerbidragFromDate.Value:yyyy-MM-dd}" +
                      $"&toDate={_lagerbidragToDate.Value:yyyy-MM-dd}" +
                      $"&duringBreak={_lagerbidragDuringBreak}";
            
            // Navigate to the report URL (will trigger download)
            NavigationManager.NavigateTo(url, forceLoad: true);
            _showLagerbidragDialog = false;
        }
    }

    private void OpenGothenburgCsvDialog()
    {
        _gbgCsvUseSemesterMin = false;
        _showGbgCsvDialog = true;
    }

    private void DownloadGothenburgCsv()
    {
        var url = $"/reports/gbg-csv?scoutGroupId={ScoutGroupId}&semesterId={SemesterId}&useSemesterMin={_gbgCsvUseSemesterMin}";
        NavigationManager.NavigateTo(url, forceLoad: true);
        _showGbgCsvDialog = false;
    }

    private async Task PreviewMembershipSync()
    {
        _syncLoading = true;
        _syncPreview = null;
        _syncResult = null;
        _showSyncDialog = true;
        StateHasChanged();

        try
        {
            _syncPreview = await MembershipSyncService.PreviewChangesAsync(
                ScoutGroupId, SemesterId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Kunde inte hämta data från Scoutnet: {ex.Message}", Severity.Error);
            _showSyncDialog = false;
        }
        finally
        {
            _syncLoading = false;
        }
    }

    private async Task PushMembershipSync()
    {
        if (_syncPreview == null) return;

        _syncPushing = true;
        StateHasChanged();

        try
        {
            var allChanges = _syncPreview.TroopChanges
                .Concat(_syncPreview.PatrolChanges)
                .ToList();

            _syncResult = await MembershipSyncService.PushChangesAsync(
                ScoutGroupId, allChanges);

            if (_syncResult.Success)
            {
                Snackbar.Add(
                    $"{_syncResult.UpdatedCount} medlem(mar) uppdaterade i Scoutnet",
                    Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fel vid synkning: {ex.Message}", Severity.Error);
        }
        finally
        {
            _syncPushing = false;
        }
    }

    private async Task OpenImportCampDialog()
    {
        _campName = string.Empty;
        _campLocation = _scoutGroup?.DefaultCampLocation ?? string.Empty;
        _campStartDate = null;
        _campEndDate = null;
        _importProjectId = 0;
        _importApiKey = string.Empty;
        _importCheckinApiKey = string.Empty;
        _importPreviewParticipants = null;
        _campImportResult = null;
        _groupProjects = null;
        _projectsError = null;
        _showImportCampDialog = true;

        // Auto-fetch projects if the API key is configured
        if (!string.IsNullOrWhiteSpace(_scoutGroup?.ApiKeyGroupProjects))
        {
            await FetchGroupProjects();
        }
    }

    private async Task FetchGroupProjects()
    {
        if (_scoutGroup == null || string.IsNullOrWhiteSpace(_scoutGroup.ApiKeyGroupProjects))
            return;

        _projectsLoading = true;
        _projectsError = null;
        StateHasChanged();

        try
        {
            _groupProjects = await ScoutnetApiClient.GetGroupProjectsAsync(
                ScoutGroupId, _scoutGroup.ApiKeyGroupProjects);

            if (_groupProjects.Count == 0)
            {
                _projectsError = "Inga arrangemang hittades. Kontrollera att medlemmar är registrerade på arrangemangen i Scoutnet.";
            }
        }
        catch (Exception ex)
        {
            _projectsError = $"Kunde inte hämta arrangemang: {ex.Message}";
            _groupProjects = null;
        }
        finally
        {
            _projectsLoading = false;
        }
    }

    private void SelectProject(ScoutnetGroupProject project)
    {
        if (project.Id.HasValue)
        {
            _importProjectId = project.Id.Value;
        }
        _campName = project.Name;
        if (project.Starts.HasValue)
        {
            _campStartDate = project.Starts.Value;
        }
        if (project.Ends.HasValue)
        {
            _campEndDate = project.Ends.Value;
        }
    }

    private async Task FetchImportPreview()
    {
        if (_importCampForm != null)
        {
            await _importCampForm.ValidateAsync();
            if (!_importCampForm.IsValid || _importProjectId <= 0) return;
        }

        _campCreating = true;
        StateHasChanged();

        try
        {
            var result = await CampService.PreviewParticipantsAsync(
                _importProjectId, _importApiKey);

            if (result.Success)
            {
                _importPreviewParticipants = result.Participants;
            }
            else
            {
                Snackbar.Add(result.ErrorMessage ?? "Kunde inte hämta deltagare.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fel: {ex.Message}", Severity.Error);
        }
        finally
        {
            _campCreating = false;
        }
    }

    private async Task ImportCampFromScoutnet()
    {
        if (_importCampForm != null)
        {
            await _importCampForm.ValidateAsync();
            if (!_importCampForm.IsValid || !_campStartDate.HasValue || !_campEndDate.HasValue) return;
        }

        _campCreating = true;
        StateHasChanged();

        try
        {
            _campImportResult = await CampService.ImportFromScoutnetAsync(
                ScoutGroupId,
                SemesterId,
                _importProjectId,
                _importApiKey,
                _campName,
                _campLocation,
                DateOnly.FromDateTime(_campStartDate!.Value),
                DateOnly.FromDateTime(_campEndDate!.Value),
                string.IsNullOrWhiteSpace(_importCheckinApiKey) ? null : _importCheckinApiKey);

            if (_campImportResult.Success)
            {
                Snackbar.Add(
                    $"Läger importerat med {_campImportResult.ParticipantsImported} deltagare!",
                    Severity.Success);
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            _campImportResult = new CampImportResult
            {
                Success = false,
                ErrorMessage = $"Fel: {ex.Message}"
            };
        }
        finally
        {
            _campCreating = false;
        }
    }

    }
