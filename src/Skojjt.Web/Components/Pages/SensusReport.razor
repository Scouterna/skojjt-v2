@page "/sk/{ScoutGroupId:int}/t/{SemesterId:int}/{TroopScoutnetId:int}/sensus"
@using Microsoft.AspNetCore.Authorization
@using Skojjt.Core.Authentication
@using Skojjt.Core.Entities
@using Skojjt.Core.Interfaces
@using Skojjt.Core.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject IScoutGroupRepository ScoutGroupRepository
@inject ISemesterRepository SemesterRepository
@inject ITroopRepository TroopRepository
@inject IMeetingRepository MeetingRepository
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager

<PageTitle>Sensus Närvarolista - @(_troop?.Name ?? "Avdelning") @(_semester?.DisplayName ?? "") - Skojjt</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (!_hasAccess)
{
    <MudAlert Severity="Severity.Error">Du har inte behörighet att visa denna avdelning.</MudAlert>
}
else if (_troop == null)
{
    <MudAlert Severity="Severity.Error">Avdelningen kunde inte hittas.</MudAlert>
}
else
{
    <div class="sensus-print-actions">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Print"
                   OnClick="PrintPage">
            Skriv ut / Spara som PDF
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="@(Invariant($"/sk/{ScoutGroupId}/t/{SemesterId}/{TroopScoutnetId}"))">
            Tillbaka
        </MudButton>
    </div>

    @foreach (var (patrolName, patrolIndex) in _patrols.Select((p, i) => (p, i)))
    {
        var persons = _personsByPatrol[patrolName];
        var leaders = persons.Where(p => p.IsLeader).ToList();
        var allPersons = persons.OrderByDescending(p => p.IsLeader).ThenBy(p => p.Person.LastName).ThenBy(p => p.Person.FirstName).ToList();

        <div class="sensus-page @(patrolIndex > 0 ? "page-break" : "")">
            <div class="sensus-header">
                <div class="sensus-logo"><img src="data:image/png;base64," alt="SENSUS" /></div>
                <div class="sensus-title">
                    <div class="sensus-title-main">NÄRVAROLISTA</div>
                    <div class="sensus-title-sub">Verksamhetsår @_verksamhetsAr</div>
                </div>
            </div>

            <div class="sensus-leader-box">
                <span class="sensus-leader-label">Ledare:</span>
                @foreach (var leader in leaders)
                {
                    <span class="sensus-leader-info">
                        @leader.Person.FullName
                        @if (!string.IsNullOrEmpty(leader.Person.Email))
                        {
                            <text> epost:@leader.Person.Email</text>
                        }
                        @if (!string.IsNullOrEmpty(leader.Person.Mobile))
                        {
                            <text> tel:@leader.Person.Mobile</text>
                        }
                    </span>
                }
            </div>

            <table class="sensus-table">
                <tr class="sensus-row-header1">
                    <td class="sensus-col-pnr">@patrolName</td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left">Mån:</td>
                    @foreach (var meeting in _meetings)
                    {
                        <td class="sensus-col-meeting sensus-border-left">@meeting.MeetingDate.Month.ToString("D2")</td>
                    }
                </tr>
                <tr class="sensus-row-header2">
                    <td class="sensus-col-pnr">@_scoutGroup?.Name</td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left">Dag:</td>
                    @foreach (var meeting in _meetings)
                    {
                        <td class="sensus-col-meeting sensus-border-left">@meeting.MeetingDate.Day.ToString("D2")</td>
                    }
                </tr>
                <tr class="sensus-row-header3">
                    <td class="sensus-col-pnr">PersonNr</td>
                    <td class="sensus-col-name sensus-border-left">Namn</td>
                    <td class="sensus-col-info sensus-border-left">Tid:</td>
                    @foreach (var meeting in _meetings)
                    {
                        <td class="sensus-col-meeting sensus-border-left sensus-small-text">@meeting.StartTime.ToString("HH:mm")</td>
                    }
                </tr>
                <tr class="sensus-row-header4">
                    <td class="sensus-col-pnr"></td>
                    <td class="sensus-col-name sensus-border-left"></td>
                    <td class="sensus-col-info sensus-border-left"></td>
                    @foreach (var meeting in _meetings)
                    {
                        var endTime = meeting.StartTime.Add(TimeSpan.FromMinutes(meeting.DurationMinutes));
                        if (endTime > new TimeOnly(23, 59))
                        {
                            endTime = new TimeOnly(23, 59);
                        }
                        <td class="sensus-col-meeting sensus-border-left sensus-small-text">@endTime.ToString("HH:mm")</td>
                    }
                </tr>

                @foreach (var tp in allPersons)
                {
                    <tr class="sensus-row-person">
                        <td class="sensus-col-pnr">@(tp.Person.PersonalNumber?.ToFormattedString() ?? string.Empty)</td>
                        <td class="sensus-col-name sensus-border-left">@tp.Person.FullName</td>
                        <td class="sensus-col-info"></td>
                        @foreach (var meeting in _meetings)
                        {
                            var attending = _attendance.Contains((tp.Person.Id, meeting.Id));
                            <td class="sensus-col-meeting sensus-border-left sensus-center">@(attending ? "1" : "")</td>
                        }
                    </tr>
                }

                <tr class="sensus-row-signature">
                    <td class="sensus-col-pnr">Ledaren intygar att ifyllda uppgifter är riktiga</td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left" title="Antal deltagare inkl. ledare">Antal:</td>
                    @foreach (var meeting in _meetings)
                    {
                        var count = allPersons.Count(p => _attendance.Contains((p.Person.Id, meeting.Id)));
                        <td class="sensus-col-meeting sensus-border-left sensus-center">@count</td>
                    }
                </tr>
                <tr class="sensus-row-signature-data">
                    <td class="sensus-col-pnr"></td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left"></td>
                    @foreach (var _ in _meetings)
                    {
                        <td class="sensus-col-meeting sensus-border-left"></td>
                    }
                </tr>
                <tr class="sensus-row-signature2">
                    <td class="sensus-col-pnr">Vikarierande Ledarens underskrift</td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left" title="Antal studietimmar à 45 min">tim:</td>
                    @foreach (var meeting in _meetings)
                    {
                        var hours = meeting.DurationMinutes / 45;
                        <td class="sensus-col-meeting sensus-border-left sensus-center">@hours</td>
                    }
                </tr>
                <tr class="sensus-row-signature-data">
                    <td class="sensus-col-pnr"></td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left"></td>
                    @foreach (var _ in _meetings)
                    {
                        <td class="sensus-col-meeting sensus-border-left"></td>
                    }
                </tr>
                <tr class="sensus-row-signature3">
                    <td class="sensus-col-pnr">Underskrift av ansvarig på studieförbundet</td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left"></td>
                    @foreach (var _ in _meetings)
                    {
                        <td class="sensus-col-meeting sensus-border-left"></td>
                    }
                </tr>
                <tr class="sensus-row-signature-data">
                    <td class="sensus-col-pnr"></td>
                    <td class="sensus-col-name"></td>
                    <td class="sensus-col-info sensus-border-left"></td>
                    @foreach (var _ in _meetings)
                    {
                        <td class="sensus-col-meeting sensus-border-left"></td>
                    }
                </tr>
            </table>
        </div>
    }
}

<style>
    .sensus-print-actions {
        display: flex;
        gap: 12px;
        padding: 16px 0;
        max-width: 297mm;
        margin: 0 auto;
    }

    .sensus-page {
        font-family: "Arial", sans-serif;
        font-size: 9px;
        color: #000;
        background: #fff;
        width: 297mm;
        min-height: 210mm;
        margin: 0 auto 24px auto;
        padding: 10mm 12mm;
        box-sizing: border-box;
        box-shadow: 0 1px 6px rgba(0,0,0,0.18);
    }

    .sensus-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding: 0 0 10px 0;
        height: 64px;
    }

    .sensus-logo {
        display: inline-block;
        position: relative;
        height: 100%;
        width: 160px;
    }

    .sensus-logo img {
        width: 100px;
        position: absolute;
        bottom: 15px;
        left: 15px;
    }

    .sensus-title {
        text-align: right;
        margin-right: 20px;
    }

    .sensus-title-main {
        text-transform: uppercase;
        font-size: 14px;
        font-weight: bold;
        padding-top: 8px;
    }

    .sensus-title-sub {
        font-size: 9px;
    }

    .sensus-leader-box {
        border-radius: 10px;
        border: 0.5px solid #000;
        padding: 3px 5px 3px 8px;
        margin: 0 0 6px 0;
        font-size: 8px;
    }

    .sensus-leader-label {
        font-weight: bold;
    }

    .sensus-leader-info {
        display: inline;
        margin-right: 6px;
    }

    .sensus-table {
        table-layout: auto;
        width: 100%;
        border-spacing: 0;
        border-collapse: separate;
    }

    .sensus-table td {
        overflow: visible;
        white-space: nowrap;
        height: 14px;
        padding: 1px 3px;
        font-size: 8px;
    }

    .sensus-table td:first-child {
        border-left: 0.5px solid #000;
    }

    .sensus-table td:last-child {
        border-right: 0.5px solid #000;
    }

    .sensus-table tr:first-child td {
        border-top: 0.5px solid #000;
    }

    .sensus-table tr:last-child td {
        border-bottom: 0.5px solid #000;
    }

    .sensus-table tr:first-child td:first-child { border-top-left-radius: 10px; }
    .sensus-table tr:first-child td:last-child { border-top-right-radius: 10px; }
    .sensus-table tr:last-child td:first-child { border-bottom-left-radius: 10px; }
    .sensus-table tr:last-child td:last-child { border-bottom-right-radius: 10px; }

    .sensus-border-left {
        border-left: 0.5px solid #000;
    }

    .sensus-col-pnr {
        min-width: 14em;
        padding-left: 1em;
    }

    .sensus-col-name {
        min-width: 14em;
    }

    .sensus-col-info {
        min-width: 3em;
    }

    .sensus-col-meeting {
        min-width: 1.4em;
        min-height: 1.4em;
    }

    .sensus-small-text {
        font-size: 7px;
    }

    .sensus-center {
        text-align: center;
    }

    .sensus-row-header3 td,
    .sensus-row-signature td,
    .sensus-row-signature2 td,
    .sensus-row-signature3 td {
        border-top: 0.5px solid #000;
    }

    .sensus-row-person td {
        border-top: 0.5px solid #000;
    }

    .page-break {
        page-break-before: always;
    }

    @@media print {
        /* Reset the entire page to white, no MudBlazor chrome */
        body, html {
            background: #fff !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
        }

        .sensus-print-actions {
            display: none !important;
        }

        /* Break out of MudBlazor layout constraints */
        .mud-appbar,
        .mud-drawer,
        .mud-drawer-overlay,
        nav,
        footer {
            display: none !important;
        }

        .mud-layout,
        .mud-main-content,
        .mud-layout-content {
            display: block !important;
            margin: 0 !important;
            padding: 0 !important;
            width: 100% !important;
            max-width: none !important;
            min-width: 0 !important;
            position: static !important;
        }

        /* Match v1 template sizing exactly — these worked on A4 landscape */
        .sensus-page {
            font-family: "Arial", sans-serif;
            font-size: 10px;
            color: #000;
            background: #fff;
            box-shadow: none;
            margin: 0;
            padding: 5px;
            width: 100%;
            min-height: auto;
            box-sizing: border-box;
            page-break-inside: avoid;
        }

        .sensus-header {
            padding: 0 0 10px 0;
            height: 64px;
        }

        .sensus-title-main {
            font-size: 16px;
            padding-top: 16px;
        }

        .sensus-title-sub {
            font-size: 10px;
        }

        .sensus-leader-box {
            font-size: 10px;
            border-radius: 15px;
            padding: 5px 5px 5px 10px;
            margin: 0 5px 0 15px;
        }

        .sensus-table {
            margin: 5px 5px 0 5px;
        }

        .sensus-table td {
            font-size: 10px;
            height: 16px;
            padding: 0 2px;
        }

        .sensus-small-text {
            font-size: 8px;
        }

        .sensus-col-pnr {
            min-width: 20em;
            padding-left: 1.5em;
        }

        .sensus-col-name {
            min-width: 20em;
        }

        .sensus-col-meeting {
            min-width: 1.5em;
            min-height: 1.5em;
        }

        .page-break {
            page-break-before: always;
        }

        @@page {
            size: A4 landscape;
            margin: 5mm;
        }
    }
</style>

@code {
    [Parameter] public int ScoutGroupId { get; set; }
    [Parameter] public int SemesterId { get; set; }
    [Parameter] public int TroopScoutnetId { get; set; }

    private ScoutGroup? _scoutGroup;
    private Semester? _semester;
    private Troop? _troop;
    private List<Meeting> _meetings = [];
    private List<TroopPerson> _troopPersons = [];
    private HashSet<(int PersonId, int MeetingId)> _attendance = [];
    private List<string> _patrols = [];
    private Dictionary<string, List<TroopPerson>> _personsByPatrol = new();
    private string _verksamhetsAr = string.Empty;
    private bool _loading = true;
    private bool _hasAccess;

    protected override async Task OnInitializedAsync()
    {
        _hasAccess = CurrentUserService.HasGroupAccess(ScoutGroupId);
        if (!_hasAccess)
        {
            _loading = false;
            return;
        }

        _scoutGroup = await ScoutGroupRepository.GetByIdAsync(ScoutGroupId);
        _semester = await SemesterRepository.GetByIdAsync(SemesterId);

        if (_semester != null)
        {
            _verksamhetsAr = _semester.Year.ToString();
        }

        var troop = await TroopRepository.GetByScoutnetIdAndSemesterAsync(TroopScoutnetId, SemesterId);
        if (troop == null)
        {
            _loading = false;
            return;
        }

        _troop = await TroopRepository.GetWithMembersAsync(troop.Id);
        if (_troop == null)
        {
            _loading = false;
            return;
        }

        _troopPersons = _troop.TroopPersons.ToList();

        var meetings = await MeetingRepository.GetByTroopWithAttendanceAsync(_troop.Id);
        _meetings = meetings.OrderBy(m => m.MeetingDate).ThenBy(m => m.StartTime).ToList();

        foreach (var meeting in _meetings)
        {
            foreach (var attendance in meeting.Attendances)
            {
                _attendance.Add((attendance.PersonId, meeting.Id));
            }
        }

        // Group persons by patrol
        var grouped = _troopPersons
            .GroupBy(tp => tp.Patrol ?? "Utan patrull")
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());

        _patrols = [.. grouped.Keys];
        _personsByPatrol = grouped;

        _loading = false;
    }

    private async Task PrintPage()
    {
        await JSRuntime.InvokeVoidAsync("window.print");
    }

    [Inject] private IJSRuntime JSRuntime { get; set; } = null!;
}
