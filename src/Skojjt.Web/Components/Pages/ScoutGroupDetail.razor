@page "/sk/{ScoutGroupId:int}"
@using Microsoft.AspNetCore.Authorization
@using Skojjt.Core.Authentication
@using Skojjt.Core.Entities
@using Skojjt.Core.Interfaces
@attribute [Authorize]
@inject IScoutGroupRepository ScoutGroupRepository
@inject ISemesterRepository SemesterRepository
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager

<PageTitle>@(_scoutGroup?.Name ?? "Scoutkår") - Skojjt</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!_hasAccess)
    {
        <MudAlert Severity="Severity.Error">
            Du har inte behörighet att visa denna scoutkår.
        </MudAlert>
    }
    else if (_scoutGroup == null)
    {
        <MudAlert Severity="Severity.Error">Scoutkåren kunde inte hittas.</MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-2">@_scoutGroup.Name</MudText>
        @if (!string.IsNullOrEmpty(_scoutGroup.OrganisationNumber))
        {
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-4">
                Org.nr: @_scoutGroup.OrganisationNumber
            </MudText>
        }

        <MudGrid>
            @* Semesters Section *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.DateRange" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Terminer</MudText>
                    </div>
                    
                    @if (_semesters.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            Inga terminer med avdelningar ännu.
                        </MudAlert>
                    }
                    else
                    {
                        <MudList T="Semester" Dense="true" Class="py-0">
                            @foreach (var semester in _semesters)
                            {
                                <MudListItem T="Semester" 
                                             Icon="@Icons.Material.Filled.CalendarMonth"
                                             Href="@($"/sk/{ScoutGroupId}/t/{semester.Id}")">
                                    <div class="d-flex justify-space-between align-center" style="width: 100%;">
                                        <MudText>@semester.DisplayName</MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudPaper>
            </MudItem>

            @* Quick Links Section *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Apps" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Snabblänkar</MudText>
                    </div>
                    
                    <MudStack Spacing="2">
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true" 
                                   StartIcon="@Icons.Material.Filled.CloudDownload"
                                   Href="@($"/sk/{ScoutGroupId}/import")"
                                   Class="justify-start"
                                   Color="Color.Primary">
                            Scoutnet Import
                        </MudButton>
                        
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true" 
                                   StartIcon="@Icons.Material.Filled.People"
                                   Href="@($"/sk/{ScoutGroupId}/p")"
                                   Class="justify-start">
                            Alla medlemmar
                        </MudButton>
                        
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true" 
                                   StartIcon="@Icons.Material.Filled.EmojiEvents"
                                   Href="@($"/sk/{ScoutGroupId}/badges")"
                                   Class="justify-start"
                                   Color="Color.Secondary">
                            Märken
                        </MudButton>
                        
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true" 
                                   StartIcon="@Icons.Material.Filled.Settings"
                                   Href="@($"/sk/{ScoutGroupId}/settings")"
                                   Class="justify-start">
                            Kårinställningar
                        </MudButton>
                        
                        <MudButton Variant="Variant.Outlined" 
                                   FullWidth="true" 
                                   StartIcon="@Icons.Material.Filled.Assessment"
                                   Href="@($"/reports/dak?scoutgroup={ScoutGroupId}")"
                                   Class="justify-start">
                            Rapporter
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* Contact Info Section *@
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.ContactMail" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Kontaktinformation</MudText>
                    </div>
                    
                    <MudGrid>
                        @if (!string.IsNullOrEmpty(_scoutGroup.Email))
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">E-post</MudText>
                                <MudLink Href="@($"mailto:{_scoutGroup.Email}")">@_scoutGroup.Email</MudLink>
                            </MudItem>
                        }
                        @if (!string.IsNullOrEmpty(_scoutGroup.Phone))
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Telefon</MudText>
                                <MudLink Href="@($"tel:{_scoutGroup.Phone}")">@_scoutGroup.Phone</MudLink>
                            </MudItem>
                        }
                        @if (!string.IsNullOrEmpty(_scoutGroup.Address))
                        {
                            <MudItem xs="12" sm="6" md="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Adress</MudText>
                                <MudText>@_scoutGroup.Address</MudText>
                                @if (!string.IsNullOrEmpty(_scoutGroup.PostalAddress))
                                {
                                    <MudText>@_scoutGroup.PostalAddress</MudText>
                                }
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public int ScoutGroupId { get; set; }

    private ScoutGroup? _scoutGroup;
    private List<Semester> _semesters = new();
    private bool _loading = true;
    private bool _hasAccess = false;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            // Check if user has access to this scout group
            _hasAccess = CurrentUserService.HasGroupAccess(ScoutGroupId);
            
            if (!_hasAccess)
            {
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Scoutkårer", href: "/sk"),
                    new BreadcrumbItem("Ingen behörighet", href: null, disabled: true)
                };
                return;
            }

            _scoutGroup = await ScoutGroupRepository.GetByIdAsync(ScoutGroupId);
            
            if (_scoutGroup != null)
            {
                var semesters = await SemesterRepository.GetByScoutGroupAsync(ScoutGroupId);
                _semesters = semesters.ToList();
                
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Scoutkårer", href: "/sk"),
                    new BreadcrumbItem(_scoutGroup.Name, href: null, disabled: true)
                };
            }
        }
        finally
        {
            _loading = false;
        }
    }
}
