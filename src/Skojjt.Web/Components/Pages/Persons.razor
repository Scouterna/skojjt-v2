@page "/persons"
@using Microsoft.AspNetCore.Authorization
@using Skojjt.Core.Entities
@using Skojjt.Core.Interfaces
@attribute [Authorize]
@inject IPersonRepository PersonRepository
@inject ISnackbar Snackbar

<PageTitle>Personer - Skojjt</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Personer</MudText>

<MudPaper Elevation="2" Class="pa-4">
    <MudTable Items="@_filteredPersons" 
              Hover="true" 
              Striped="true"
              Dense="true"
              Loading="@_loading"
              LoadingProgressColor="Color.Primary"
              Filter="FilterFunc"
              FixedHeader="true"
              Height="calc(100vh - 300px)">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" 
                          Placeholder="S÷k..." 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" 
                          Class="mt-0"
                          Immediate="true" />
            <MudSpacer />
            <MudSwitch @bind-Value="_showRemoved" 
                       Label="Visa borttagna" 
                       Color="Color.Warning" 
                       Class="mr-4" />
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Download"
                       OnClick="ExportToCsv">
                Exportera
            </MudButton>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<Person, object>(x => x.FullName)">Namn</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Person, object?>(x => x.BirthDate)">F÷delsedatum</MudTableSortLabel></MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Telefon</MudTh>
            <MudTh>Mobil</MudTh>
            <MudTh>Adress</MudTh>
            <MudTh>Postadress</MudTh>
            <MudTh>Medlemsňr</MudTh>
            <MudTh>Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Namn">
                <MudLink Href="@($"/persons/{context.Id}")" Class="@(context.Removed ? "mud-text-disabled" : "")">
                    @context.FullName
                </MudLink>
            </MudTd>
            <MudTd DataLabel="F÷delsedatum">
                @(context.BirthDate?.ToString("yyyy-MM-dd") ?? "")
            </MudTd>
            <MudTd DataLabel="Email">
                @if (!string.IsNullOrEmpty(context.Email))
                {
                    <MudLink Href="@($"mailto:{context.Email}")">@context.Email</MudLink>
                }
            </MudTd>
            <MudTd DataLabel="Telefon">
                @if (!string.IsNullOrEmpty(context.Phone))
                {
                    <MudLink Href="@($"tel:{context.Phone}")">@context.Phone</MudLink>
                }
            </MudTd>
            <MudTd DataLabel="Mobil">
                @if (!string.IsNullOrEmpty(context.Mobile))
                {
                    <MudLink Href="@($"tel:{context.Mobile}")">@context.Mobile</MudLink>
                }
            </MudTd>
            <MudTd DataLabel="Adress">@context.Street</MudTd>
            <MudTd DataLabel="Postadress">
                @if (!string.IsNullOrEmpty(context.ZipCode))
                {
                    @($"{context.ZipCode} {context.ZipName}")
                }
            </MudTd>
            <MudTd DataLabel="Medlemsňr">
                @if (context.MemberYears.Length > 0)
                {
                    @string.Join(", ", context.MemberYears)
                }
            </MudTd>
            <MudTd DataLabel="Status">
                @if (context.Removed)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Borttagen</MudChip>
                }
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 50, 100, 250, 500 }" />
        </PagerContent>
        <NoRecordsContent>
            <MudText>Inga personer hittades</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

<MudDivider Class="my-4" />

<MudExpansionPanels>
    <MudExpansionPanel Text="Export och verktyg" Icon="@Icons.Material.Filled.Build">
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
                <MudButton Variant="Variant.Outlined" 
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.CloudDownload"
                           Href="/import">
                    Synka frňn Scoutnet
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudButton Variant="Variant.Outlined" 
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.ListAlt"
                           OnClick="ExportMemberListForGbg">
                    Medlemslista f÷r G÷teborgs Kommun
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    private List<Person> _persons = new();
    private List<Person> _filteredPersons = new();
    private string _searchString = "";
    private bool _showRemoved = false;
    private bool _loading = true;
    private int _scoutGroupId = 0; // TODO: Get from user context

    protected override async Task OnInitializedAsync()
    {
        await LoadPersons();
    }

    private async Task LoadPersons()
    {
        _loading = true;
        try
        {
            if (_scoutGroupId > 0)
            {
                var persons = await PersonRepository.GetByScoutGroupAsync(_scoutGroupId);
                _persons = persons.ToList();
            }
            ApplyFilters();
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        _filteredPersons = _persons
            .Where(p => _showRemoved || !p.Removed)
            .ToList();
    }

    private bool FilterFunc(Person person)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        var search = _searchString.ToLower();
        return person.FirstName.ToLower().Contains(search) ||
               person.LastName.ToLower().Contains(search) ||
               (person.Email?.ToLower().Contains(search) ?? false) ||
               (person.Phone?.Contains(search) ?? false) ||
               (person.Mobile?.Contains(search) ?? false);
    }

    private void ExportToCsv()
    {
        // TODO: Implement CSV export
        Snackbar.Add("CSV-export kommer snart!", Severity.Info);
    }

    private void ExportMemberListForGbg()
    {
        // TODO: Implement Gothenburg member list export
        Snackbar.Add("Medlemslista f÷r G÷teborg kommer snart!", Severity.Info);
    }
}
