@using Microsoft.EntityFrameworkCore
@using Skojjt.Core.Entities
@using Skojjt.Core.Interfaces
@using Skojjt.Infrastructure.Data
@inject IDbContextFactory<SkojjtDbContext> DbContextFactory
@inject ISnackbar Snackbar

<MudText Typo="Typo.h6" Class="mb-4">Anvðndare</MudText>

<MudAlert Severity="Severity.Info" Class="mb-4">
    Administrat—rsbeh—righet hanteras via ScoutID. Anvðndare med rollen <strong>scoutid_admin</strong> i ScoutID blir automatiskt administrat—rer i Skojjt.
</MudAlert>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudTable Items="@_allUsers" Hover="true" Breakpoint="Breakpoint.Sm" Dense="true" Filter="FilterUsers">
        <ToolBarContent>
            <MudTextField @bind-Value="_searchString" 
                          Placeholder="S—k anvðndare..." 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Search" 
                          IconSize="Size.Medium" 
                          Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>E-post</MudTh>
            <MudTh>Namn</MudTh>
            <MudTh>Senaste inloggning</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="E-post">@context.Email</MudTd>
            <MudTd DataLabel="Namn">@(context.DisplayName ?? context.Name ?? "-")</MudTd>
            <MudTd DataLabel="Senaste inloggning">
                @(context.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Aldrig")
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<User> _allUsers = new();
    private bool _loading = true;
    private string _searchString = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();

            _allUsers = await context.Users
                .OrderBy(u => u.Email)
                .ToListAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterUsers(User user)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        var search = _searchString.ToLower();
        return user.Email.Contains(search, StringComparison.OrdinalIgnoreCase) ||
               (user.DisplayName?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
               (user.Name?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
               user.Id.Contains(search, StringComparison.OrdinalIgnoreCase);
    }
}
