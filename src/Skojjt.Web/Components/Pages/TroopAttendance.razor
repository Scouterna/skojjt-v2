    private int GetColspan()
    {
        var cols = 1; // Name
        if (_showExtraInfo) cols += 4; // Age + Leader + Patrol + Action
        cols += _meetings.Count; // Meeting columns
        if (_meetings.Count > 0) cols += 1; // Sum column only if there are meetings
        return cols;
    }

    private bool IsAttending(int personId, int meetingId) =>
        _attendance.TryGetValue((personId, meetingId), out var attending) && attending;

    private void OnAttendanceChanged(int personId, int meetingId, bool attending)
    {
        if (_troop?.IsLocked == true) return;
        var key = (personId, meetingId);
        _attendance[key] = attending;
        var originalValue = _originalAttendance.TryGetValue(key, out var orig) && orig;
        if (attending != originalValue) _pendingChanges.Add(key);
        else _pendingChanges.Remove(key);
        _saveStatus = _pendingChanges.Count > 0 ? SaveStatus.Unsaved : SaveStatus.Saved;
        _ = DebouncedSaveAsync();
        StateHasChanged();
    }

    private async Task DebouncedSaveAsync()
    {
        _saveDebounceTokenSource?.Cancel();
        _saveDebounceTokenSource = new CancellationTokenSource();
        var token = _saveDebounceTokenSource.Token;
        try
        {
            await Task.Delay(SaveDebounceMs, token);
            if (!token.IsCancellationRequested && _pendingChanges.Count > 0)
                await SaveAttendanceChangesAsync();
        }
        catch (OperationCanceledException) { }
    }

    private async Task SaveAttendanceChangesAsync()
    {
        if (_pendingChanges.Count == 0) return;
        _saveStatus = SaveStatus.Saving;
        StateHasChanged();
        try
        {
            var changesToSave = _pendingChanges.ToList();
            var attendanceChanges = changesToSave
                .Select(key => (key.MeetingId, key.PersonId, _attendance.TryGetValue(key, out var a) && a))
                .ToList();
            
            await MeetingRepository.SetAttendanceBatchAsync(attendanceChanges);
            
            // Broadcast changes to other components
            var notifyChanges = attendanceChanges.Select(c => (c.PersonId, c.MeetingId, c.Item3)).ToList();
            await NotificationService.NotifyAttendanceChangedBatchAsync(_troop!.Id, notifyChanges, _instanceId);
            
            foreach (var key in changesToSave)
            {
                if (_attendance.TryGetValue(key, out var value)) _originalAttendance[key] = value;
                else _originalAttendance.Remove(key);
                _pendingChanges.Remove(key);
            }
            _saveStatus = _pendingChanges.Count > 0 ? SaveStatus.Unsaved : SaveStatus.Saved;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Kunde inte spara: {ex.Message}", Severity.Error);
            _saveStatus = SaveStatus.Unsaved;
        }
        StateHasChanged();
    }

