@page "/sk/{ScoutGroupId:int}/t/{SemesterId:int}/{TroopScoutnetId:int}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@using MudBlazor
@using Skojjt.Core.Authentication
@using Skojjt.Core.Entities
@using Skojjt.Core.Interfaces
@using Skojjt.Core.Services
@using Skojjt.Web.Services
@attribute [Authorize]
@inject IScoutGroupRepository ScoutGroupRepository
@inject ISemesterRepository SemesterRepository
@inject ITroopRepository TroopRepository
@inject IMeetingRepository MeetingRepository
@inject IPersonRepository PersonRepository
@inject IUnitOfWork UnitOfWork
@inject ICurrentUserService CurrentUserService
@inject AttendanceNotificationService NotificationService
@inject AttendanceStateService StateService
@inject IBadgeService BadgeService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Närvaro - @(_troop?.Name ?? "Avdelning") - Skojjt</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-2 mt-sm-4 mb-4 mb-sm-8">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!_hasAccess)
    {
        <MudAlert Severity="Severity.Error">
            Du har inte behörighet att visa denna avdelning.
        </MudAlert>
    }
    else if (_troop == null)
    {
        <MudAlert Severity="Severity.Error">Avdelningen kunde inte hittas.</MudAlert>
    }
    else
    {
        <div class="d-flex flex-wrap align-center justify-space-between mb-4 gap-2">
            <div>
                <MudText Typo="Typo.h4">@_troop.Name</MudText>
                <MudText Typo="Typo.subtitle1" Color="Color.Secondary">
                    @_semester?.DisplayName - @_scoutGroup?.Name
                    @if (_troop.IsLocked)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" Class="ml-2" />
                        <span class="mud-text-warning">Låst</span>
                    }
                    <MudIcon Icon="@Icons.Material.Filled.Wifi" Size="Size.Small" Color="Color.Success" Class="ml-2" 
                             Title="Realtidssynkronisering aktiv" />
                </MudText>
            </div>
            
            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           OnClick="@(() => _showNewMeetingDialog = true)"
                           Disabled="@_troop.IsLocked">
                    Nytt möte
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Hiking"
                           OnClick="OpenNewHikeDialog"
                           Disabled="@_troop.IsLocked">
                    Läger
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.PersonAdd"
                           OnClick="@(() => _showAddMemberDialog = true)">
                    Lägg till
                </MudButton>
            </MudButtonGroup>
        </div>

        @* Attendance Grid *@
        <MudPaper Elevation="2" Class="pa-2 pa-sm-4">
            <div class="d-flex flex-wrap justify-space-between align-center mb-4 gap-2">
                <MudText Typo="Typo.h6">Närvaroregistrering</MudText>
                <div class="d-flex align-center gap-2">
                    <MudChip T="string" 
                             Size="Size.Small" 
                             Color="@GetSaveStatusColor()" 
                             Icon="@GetSaveStatusIcon()">
                        @GetSaveStatusText()
                    </MudChip>
                    <MudSwitch @bind-Value="_groupByPatrol" 
                               Label="Gruppera patrull" 
                               Color="Color.Secondary"
                               Size="Size.Small" />
                    <MudSwitch @bind-Value="_showExtraInfo" 
                               Label="Visa detaljer" 
                               Color="Color.Primary"
                               Size="Size.Small" />
                </div>
            </div>

            @if (_troopPersons.Count == 0)
            {
                <MudAlert Severity="Severity.Info">
                    Inga medlemmar i avdelningen. Lägg till medlemmar för att börja registrera närvaro.
                </MudAlert>
            }
            else
            {
                @if (_meetings.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-4">
                        Inga möten registrerade. 
                        <MudLink OnClick="@(() => _showNewMeetingDialog = true)" Class="cursor-pointer">
                            Skapa ett möte
                        </MudLink> för att börja registrera närvaro.
                    </MudAlert>
                }
                
                <div class="attendance-grid-wrapper">
                    <table class="attendance-grid">
                        <thead>
                            <tr>
                                <th class="sticky-col name-col">Namn</th>
                                @if (_showExtraInfo)
                                {
                                    <th class="age-col">Ålder</th>
                                    <th class="leader-col">Ledare</th>
                                    <th class="patrol-col">Patrull</th>
                                    <th class="action-col"></th>
                                }
                                @for (var i = 0; i < _meetings.Count; i++)
                                {
                                    var meeting = _meetings[i];
                                    var meetingIndex = i;
                                    <th class="meeting-col @(meeting.IsHike ? "hike-meeting" : "")">
                                        <MudTooltip Text="@($"{meeting.Name} - {meeting.MeetingDate:yyyy-MM-dd}")">
                                            <a href="@($"/meetings/{meeting.Id}")" class="meeting-link">
                                                @meeting.MeetingDate.Day/@meeting.MeetingDate.Month
                                                @if (meeting.IsHike)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Hiking" Size="Size.Small" />
                                                }
                                            </a>
                                        </MudTooltip>
                                        @if (!(_troop?.IsLocked ?? true))
                                        {
                                            <MudMenu Icon="@Icons.Material.Filled.MoreHoriz"
                                                     Size="Size.Small"
                                                     Dense="true"
                                                     Color="Color.Primary"
                                                     AnchorOrigin="Origin.BottomCenter"
                                                     TransformOrigin="Origin.TopCenter"
                                                     Class="meeting-menu">
                                                <MudMenuItem OnClick="@(() => SelectAllForMeeting(meeting.Id))">Alla</MudMenuItem>
                                                <MudMenuItem OnClick="@(() => SelectNoneForMeeting(meeting.Id))">Ingen</MudMenuItem>
                                                @if (meetingIndex < _meetings.Count - 1)
                                                {
                                                    <MudMenuItem OnClick="@(() => CopyFromAdjacentMeeting(meeting.Id, _meetings[meetingIndex + 1].Id))">
                                                        Som förra
                                                    </MudMenuItem>
                                                }
                                            </MudMenu>
                                        }
                                    </th>
                                }
                                @if (_meetings.Count > 0)
                                {
                                    <th class="sum-col">&#931;</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (_groupByPatrol)
                            {
                                @foreach (var group in GetGroupedByPatrol())
                                {
                                    <tr class="patrol-header-row">
                                        <td colspan="@GetColspan()" class="patrol-header">
                                            <MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-2" />
                                            <strong>@(string.IsNullOrEmpty(group.Key) ? "Ingen patrull" : group.Key)</strong>
                                            <span class="ml-2">(@group.Count() personer)</span>
                                        </td>
                                    </tr>
                                    @foreach (var tp in group)
                                    {
                                        @PersonRow(tp)
                                    }
                                }
                            }
                            else
                            {
                                @foreach (var tp in _troopPersons)
                                {
                                    @PersonRow(tp)
                                }
                            }
                        </tbody>
                        @if (_meetings.Count > 0)
                        {
                            <tfoot>
                                <tr class="footer-row">
                                    <td class="sticky-col name-col">
                                        <MudTooltip Text="Ledare / Deltagare">
                                            <strong>Totalt</strong>
                                        </MudTooltip>
                                    </td>
                                    @if (_showExtraInfo)
                                    {
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                    }
                                    @foreach (var meeting in _meetings)
                                    {
                                        var (leaders, scouts) = GetMeetingAttendanceSplit(meeting.Id);
                                        <td class="sum-col">
                                            <strong>@scouts+@leaders</strong>
                                        </td>
                                    }
                                    <td class="sum-col"></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            }
        </MudPaper>

        <MudExpansionPanels Class="mt-4">
            <MudExpansionPanel Text="Märken" Icon="@Icons.Material.Filled.EmojiEvents">
                @if (_troopBadges.Count == 0 && _availableBadges.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Inga märken definierade för kåren. <MudLink Href="@($"/sk/{ScoutGroupId}/badges")">Skapa märken</MudLink> först.
                    </MudAlert>
                }
                else
                {
                    @if (_troopBadges.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Tilldelade märken</MudText>
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            @foreach (var badge in _troopBadges)
                            {
                                <MudChip T="string" Color="Color.Primary"
                                         OnClose="@(() => UnassignBadge(badge.Id))"
                                         Icon="@Icons.Material.Filled.EmojiEvents">
                                    <MudLink Href="@($"/sk/{ScoutGroupId}/t/{SemesterId}/{TroopScoutnetId}/badges/{badge.Id}")"
                                             Color="Color.Inherit" Underline="Underline.None">
                                        @badge.Name
                                    </MudLink>
                                </MudChip>
                            }
                        </div>
                    }

                    @if (_availableBadges.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Lägg till märke</MudText>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var badge in _availableBadges)
                            {
                                <MudChip T="string" Color="Color.Default"
                                         OnClick="@(() => AssignBadge(badge.Id))"
                                         Icon="@Icons.Material.Filled.Add">
                                    @badge.Name
                                </MudChip>
                            }
                        </div>
                    }
                }
            </MudExpansionPanel>
            <MudExpansionPanel Text="Inställningar & Export" Icon="@Icons.Material.Filled.Settings">
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <ExportButton ExportUrl="@($"/reports/dak?scoutnetId={_troop.ScoutnetId}&semesterId={_troop.SemesterId}")"
                                      ScoutGroupId="@ScoutGroupId"
                                      Icon="@Icons.Material.Filled.FileDownload">
                            DAK-export
                        </ExportButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <ExportButton ExportUrl="@($"/reports/json?scoutnetId={_troop.ScoutnetId}&semesterId={_troop.SemesterId}")"
                                      ScoutGroupId="@ScoutGroupId"
                                      Icon="@Icons.Material.Filled.DataObject">
                            JSON-export
                        </ExportButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <ExportButton ExportUrl="@($"/reports/excel-gbg?scoutnetId={_troop.ScoutnetId}&semesterId={_troop.SemesterId}")"
                                      ScoutGroupId="@ScoutGroupId"
                                      Icon="@Icons.Material.Filled.TableChart">
                            Excel (Göteborg)
                        </ExportButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Variant="Variant.Outlined" FullWidth="true"
                                   StartIcon="@((_troop.IsLocked ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.Lock))"
                                   Color="@(_troop.IsLocked ? Color.Success : Color.Warning)"
                                   OnClick="ToggleLock">
                            @(_troop.IsLocked ? "Lås upp" : "Lås närvaro")
                        </MudButton>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudButton Variant="Variant.Outlined" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.Tune"
                                   Href="@($"/sk/{ScoutGroupId}/t/{SemesterId}/{TroopScoutnetId}/settings")">
                                    Standardvärden
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
</MudContainer>

<MudDialog @bind-Visible="_showNewMeetingDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Event" Class="mr-2" />
            @(_newMeetingIsHike ? "Nytt läger" : "Nytt möte")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_meetingForm">
            <MudTextField @bind-Value="_newMeetingName" Label="Namn" Variant="Variant.Outlined" Required="true" MaxLength="50" />
            <MudDatePicker @bind-Date="_newMeetingDate" Label="Datum" Variant="Variant.Outlined" Required="true"
                           DateFormat="yyyy-MM-dd"
                           Validation="@((DateOnly? date) => ValidateMeetingDate(date))" />
            <MudTimePicker @bind-Time="_newMeetingTime" Label="Starttid" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="_newMeetingDuration" Label="Längd (minuter)" Variant="Variant.Outlined" Min="1" MaxLength="1440"/>
            <MudCheckBox @bind-Value="_newMeetingIsHike" Label="Läger/vandring" Color="Color.Primary" />
            @if (_newMeetingIsHike)
            {
                <MudNumericField @bind-Value="_newHikeDays" Label="Antal dagar" Variant="Variant.Outlined" Min="1" Max="30" />
            }
            <MudTextField @bind-Value="_newMeetingLocation" Label="Plats" Variant="Variant.Outlined" MaxLength="50" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showNewMeetingDialog = false)">Avbryt</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateMeeting">Skapa</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showAddMemberDialog" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
            Lägg till medlem
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
            Sök bland kårens befintliga medlemmar eller skapa en ny person i Scoutnet.
        </MudAlert>
        <MudTextField @bind-Value="_memberSearchText" 
                      Label="Sök namn" 
                      Variant="Variant.Outlined"
                      Immediate="true" 
                      DebounceInterval="300"
                      TextChanged="OnMemberSearchTextChanged"
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" />
        
        @if (_searchingMembers)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-2" />
        }
        else if (_memberSearchResults.Count > 0)
        {
            <MudList T="Person" Dense="true" Class="mt-2">
                @foreach (var person in _memberSearchResults)
                {
                    var isAlreadyMember = _troopPersonIds.Contains(person.Id);
                    <MudListItem T="Person" Class="@(isAlreadyMember ? "mud-text-disabled" : "")">
                        <div class="d-flex align-center justify-space-between w-100">
                            <div>
                                <MudText>@person.FullName</MudText>
                                @if (person.Age > 0)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@person.Age år</MudText>
                                }
                            </div>
                            @if (isAlreadyMember)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">Redan medlem</MudChip>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Text" 
                                           Color="Color.Primary" 
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="@(() => AddMemberToTroop(person))">
                                    Lägg till
                                </MudButton>
                            }
                        </div>
                    </MudListItem>
                }
            </MudList>
        }
        else if (!string.IsNullOrWhiteSpace(_memberSearchText) && _memberSearchText.Length >= 2)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-4 text-center">
                Inga personer hittades med det namnet.
            </MudText>
            <div class="d-flex justify-center mt-3">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PersonAdd"
                           Href="@($"/sk/{ScoutGroupId}/t/{SemesterId}/{TroopScoutnetId}/add-member")"
                           Size="Size.Small">
                    Skapa ny person i Scoutnet
                </MudButton>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_memberSearchText))
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-4 text-center">
                Skriv minst 2 tecken för att söka.
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.PersonAdd"
                   Href="@($"/sk/{ScoutGroupId}/t/{SemesterId}/{TroopScoutnetId}/add-member")">
            Skapa ny person
        </MudButton>
        <MudSpacer />
        <MudButton OnClick="CloseAddMemberDialog">Stäng</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .attendance-grid-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .attendance-grid { border-collapse: separate; border-spacing: 0; width: 100%; min-width: 600px; }
    .attendance-grid th, .attendance-grid td { padding: 4px 8px; border: 1px solid var(--mud-palette-lines-default); text-align: center; white-space: nowrap; }
    .attendance-grid thead th { background: var(--mud-palette-surface); position: sticky; top: 0; z-index: 10; }
    .sticky-col { position: sticky; left: 0; background: var(--mud-palette-background); z-index: 5; }
    .attendance-grid thead th.sticky-col { z-index: 15; }
    .name-col { text-align: left !important; min-width: 150px; max-width: 200px; overflow: hidden; text-overflow: ellipsis; }
    .meeting-col { min-width: 60px; white-space: normal; }
    .meeting-menu { display: block; margin: 2px auto 0; }
    .meeting-menu .mud-menu-activator .mud-button-root { padding: 2px !important; min-width: 0 !important; min-height: 0 !important; border-radius: 4px; }
    .meeting-menu .mud-menu-activator .mud-button-root:hover { background: var(--mud-palette-action-default-hover); }
    .hike-meeting { background: var(--mud-palette-info-lighten) !important; }
    .check-col { padding: 0 !important; position: relative; z-index: 1; }
    .check-col .mud-input-control { margin: 0 auto; }
    .check-col .mud-checkbox { margin: 0; padding: 4px; }
    .sum-col { font-weight: bold; min-width: 40px; }
    .meeting-link { color: inherit; text-decoration: none; }
    .meeting-link:hover { text-decoration: underline; }
    .person-link { color: var(--mud-palette-primary); text-decoration: none; }
    .person-link:hover { text-decoration: underline; }
    
    /* Leader column styles */
    .leader-col { min-width: 60px; }
    
    /* Action column styles */
    .action-col { min-width: 40px; padding: 0 !important; }
    
    /* Patrol column styles */
    .patrol-col { min-width: 120px; text-align: left !important; }
    .patrol-display { cursor: pointer; display: flex; align-items: center; padding: 2px 4px; border-radius: 4px; }
    .patrol-display:hover { background: var(--mud-palette-action-default-hover); }
    .patrol-edit-icon { opacity: 0; transition: opacity 0.2s; }
    .patrol-display:hover .patrol-edit-icon { opacity: 0.7; }
    .patrol-placeholder { color: var(--mud-palette-text-disabled); font-style: italic; font-size: 0.85em; }
    .patrol-input { max-width: 100px; }
    .patrol-input .mud-input-slot { padding: 2px 4px !important; font-size: 0.875rem; }
    
    /* Patrol group header row */
    .patrol-header-row { background: var(--mud-palette-background-gray) !important; }
    .patrol-header-row td { background: var(--mud-palette-background-gray) !important; }
    .patrol-header { text-align: left !important; padding: 8px 12px !important; }
    :root[data-mud-dark-mode="true"] .patrol-header-row,
    .mud-theme-dark .patrol-header-row { background: #424242 !important; }
    :root[data-mud-dark-mode="true"] .patrol-header-row td,
    .mud-theme-dark .patrol-header-row td { background: #424242 !important; }
    
    /* Leader row - Light mode */
    .leader-row { background: #E3F2FD; color: #0D47A1; }
    .leader-row .sticky-col { background: #E3F2FD; color: #0D47A1; }
    .leader-row .person-link { color: #0D47A1; font-weight: 600; }
    /* Dark mode support for leader rows - deeper blue background with bright text */
    :root[data-mud-dark-mode="true"] .leader-row,
    .mud-theme-dark .leader-row { background: #0D47A1; color: #FFFFFF; }
    :root[data-mud-dark-mode="true"] .leader-row .sticky-col,
    .mud-theme-dark .leader-row .sticky-col { background: #0D47A1; color: #FFFFFF; }
    :root[data-mud-dark-mode="true"] .leader-row .person-link,
    .mud-theme-dark .leader-row .person-link { color: #90CAF9; font-weight: 600; }
    /* Dark mode - improve regular row contrast */
    :root[data-mud-dark-mode="true"] .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row),
    .mud-theme-dark .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row) { background: #2D2D2D; color: #E0E0E0; }
    :root[data-mud-dark-mode="true"] .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row) .sticky-col,
    .mud-theme-dark .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row) .sticky-col { background: #2D2D2D; color: #E0E0E0; }
    :root[data-mud-dark-mode="true"] .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row):nth-child(even),
    .mud-theme-dark .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row):nth-child(even) { background: #363636; }
    :root[data-mud-dark-mode="true"] .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row):nth-child(even) .sticky-col,
    .mud-theme-dark .attendance-grid tbody tr:not(.leader-row):not(.patrol-header-row):nth-child(even) .sticky-col { background: #363636; }
    :root[data-mud-dark-mode="true"] .person-link,
    .mud-theme-dark .person-link { color: #64B5F6; }
    .footer-row { background: var(--mud-palette-surface); }
    .footer-row .sticky-col { background: var(--mud-palette-surface); }
    @@media (max-width: 600px) {
        .attendance-grid { min-width: auto; }
        .attendance-grid th, .attendance-grid td { padding: 2px 3px; font-size: 0.8rem; }
        .name-col { min-width: 80px; max-width: 100px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .name-col .mud-chip { display: none; }
        .meeting-col { min-width: 40px; }
        .check-col .mud-checkbox { padding: 2px; }
        .sum-col { min-width: 30px; }
    }
</style>

@code {
    [Parameter] public int ScoutGroupId { get; set; }
    [Parameter] public int SemesterId { get; set; }
    [Parameter] public int TroopScoutnetId { get; set; }

    private ScoutGroup? _scoutGroup;
    private Semester? _semester;
    private Troop? _troop;
    private List<TroopPerson> _troopPersons = new();
    private List<Meeting> _meetings = new();
    private Dictionary<(int PersonId, int MeetingId), bool> _attendance = new();
    private Dictionary<(int PersonId, int MeetingId), bool> _originalAttendance = new();
    private HashSet<(int PersonId, int MeetingId)> _pendingChanges = new();
    private bool _loading = true;
    private bool _hasAccess = false;
    private bool _showExtraInfo = false;
    private bool _groupByPatrol = false;
