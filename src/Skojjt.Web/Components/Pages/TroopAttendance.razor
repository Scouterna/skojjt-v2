    private int GetAttendanceCount(int personId) => _meetings.Count(m => IsAttending(personId, m.Id));
    private (int Leaders, int Scouts) GetMeetingAttendanceSplit(int meetingId)
    {
        var leaders = _troopPersons.Count(tp => tp.IsLeader && IsAttending(tp.PersonId, meetingId));
        var scouts = _troopPersons.Count(tp => !tp.IsLeader && IsAttending(tp.PersonId, meetingId));
        return (leaders, scouts);
    }

    private bool IsBirthdayToday(Person person)
    {
        if (person.BirthDate == null) return false;
        var today = DateOnly.FromDateTime(DateTime.Today);
        return person.BirthDate.Value.Month == today.Month && person.BirthDate.Value.Day == today.Day;
    }

    private void OpenNewHikeDialog()
    {
        _newMeetingName = "Läger";
        _newMeetingIsHike = true;
        _newHikeDays = 1;
        _showNewMeetingDialog = true;
    }

    private async Task CreateMeeting()
    {
        if (_meetingForm != null && _newMeetingDate.HasValue)
        {
            await _meetingForm.Validate();
            if (_meetingForm.IsValid)
            {
                try
                {
                    var startDate = DateOnly.FromDateTime(_newMeetingDate.Value);
                    var startTime = _newMeetingTime.HasValue ? TimeOnly.FromTimeSpan(_newMeetingTime.Value) : new TimeOnly(18, 30);
                    var totalDays = _newMeetingIsHike ? Math.Max(1, _newHikeDays) : 1;
                    var createdCount = 0;
                    var skippedCount = 0;

                    for (var day = 0; day < totalDays; day++)
                    {
                        var meetingDate = startDate.AddDays(day);

                        if (_semester != null && !_semester.IsValidDate(meetingDate))
                        {
                            skippedCount++;
                            continue;
                        }

                        var meeting = new Meeting
                        {
                            TroopId = _troop!.Id,
                            Name = totalDays > 1 ? $"{_newMeetingName} dag {day + 1}" : _newMeetingName,
                            MeetingDate = meetingDate,
                            StartTime = startTime,
                            DurationMinutes = _newMeetingDuration,
                            Location = _newMeetingLocation ?? "",
                            IsHike = _newMeetingIsHike
                        };

                        await MeetingRepository.AddAsync(meeting);
                        createdCount++;
                    }

                    await UnitOfWork.SaveChangesAsync();

                    // Broadcast meeting added to other components
                    await NotificationService.NotifyMeetingChangedAsync(_troop!.Id, 0, MeetingChangeType.Added, _instanceId);

                    if (skippedCount > 0)
                    {
                        Snackbar.Add($"{createdCount} lägerdagar skapade. {skippedCount} dag(ar) hoppades över (utanför terminen).", Severity.Warning);
                    }
                    else if (createdCount > 1)
                    {
                        Snackbar.Add($"{createdCount} lägerdagar skapade!", Severity.Success);
                    }
                    else
                    {
                        Snackbar.Add($"Möte '{_newMeetingName}' skapat!", Severity.Success);
                    }

                    _showNewMeetingDialog = false;
                    _newMeetingName = "Möte";
                    _newMeetingDuration = _troop?.DefaultDurationMinutes ?? 90;
                    _newMeetingIsHike = false;
                    _newHikeDays = 1;
                    _newMeetingDate = DateTime.Today;
                    _newMeetingTime = _troop?.DefaultStartTime.ToTimeSpan() ?? new TimeSpan(18, 30, 0);
                    _newMeetingLocation = _troop?.DefaultMeetingLocation;
                    await LoadData();
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Kunde inte skapa möte: {ex.Message}", Severity.Error);
                }
            }
        }
    }

