    private async Task SavePatrol(int personId)
    {
        if (_editingPatrolPersonId != personId) return;
        
        var troopPerson = _troopPersons.FirstOrDefault(tp => tp.PersonId == personId);
        if (troopPerson == null) return;
        
        var newPatrol = string.IsNullOrWhiteSpace(_editingPatrolValue) ? null : _editingPatrolValue.Trim();
        
        try
        {
            await TroopRepository.UpdatePatrolAsync(_troop!.Id, personId, newPatrol);
            troopPerson.Patrol = newPatrol;

            // Broadcast the change to other components
            await NotificationService.NotifyPatrolChangedAsync(_troop.Id, personId, newPatrol, _instanceId);
            
            Snackbar.Add("Patrull uppdaterad", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Kunde inte spara patrull: {ex.Message}", Severity.Error);
        }
        finally
        {
            CancelPatrolEdit();
        }
    }

