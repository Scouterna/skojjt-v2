    // Member search and add methods
    private async Task OnMemberSearchTextChanged(string searchText)
    {
        _memberSearchText = searchText;
        
        if (string.IsNullOrWhiteSpace(searchText) || searchText.Length < 2)
        {
            _memberSearchResults.Clear();
            return;
        }
        
        _searchingMembers = true;
        StateHasChanged();
        
        try
        {
            var results = await PersonRepository.SearchByNameAsync(ScoutGroupId, searchText);
            _memberSearchResults = results.Take(20).ToList(); // Limit to 20 results
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sökning misslyckades: {ex.Message}", Severity.Error);
            _memberSearchResults.Clear();
        }
        finally
        {
            _searchingMembers = false;
            StateHasChanged();
        }
    }

