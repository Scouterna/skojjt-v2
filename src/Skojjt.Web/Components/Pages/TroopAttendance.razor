    private async Task RemoveMemberFromTroop(TroopPerson tp)
    {
        // First click - show confirmation
        if (_pendingRemovePersonId != tp.PersonId)
        {
            _pendingRemovePersonId = tp.PersonId;
            return;
        }
        
        // Second click - actually remove
        try
        {
            await TroopRepository.RemoveMemberAsync(_troop!.Id, tp.PersonId);

            // Broadcast member removed to other components
            await NotificationService.NotifyMemberChangedAsync(_troop.Id, tp.PersonId, TroopMemberChangeType.Removed, _instanceId);
            
            // Remove from local list
            _troopPersons.Remove(tp);
            _troopPersonIds.Remove(tp.PersonId);
            
            Snackbar.Add($"{tp.Person.FullName} har tagits bort från avdelningen", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Kunde inte ta bort medlem: {ex.Message}", Severity.Error);
        }
        finally
        {
            _pendingRemovePersonId = null;
        }
    }

