    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        
        // Unregister all handlers from state service
        if (_attendanceHandlerId != null)
            StateService.UnregisterAttendanceHandler(_attendanceHandlerId);
        if (_patrolHandlerId != null)
            StateService.UnregisterPatrolHandler(_patrolHandlerId);
        if (_meetingHandlerId != null)
            StateService.UnregisterMeetingHandler(_meetingHandlerId);
        if (_memberHandlerId != null)
            StateService.UnregisterMemberHandler(_memberHandlerId);
        
        _saveDebounceTokenSource?.Cancel();
        _saveDebounceTokenSource?.Dispose();
        
        if (_pendingChanges.Count > 0)
        {
            try { await SaveAttendanceChangesAsync(); } catch { }
        }
    }

    private string ValidateMeetingDate(DateOnly? date)
    {
        if (date == null)
            return "Datum krävs";

        if (_troop == null)
            return "Avdelningsdata saknas";

        if (!_troop.Semester.IsValidDate(date.Value))
        {
            return $"Datumet ligger utanför avdelningens termin ({_troop.Semester.DisplayName})";
        }

        return "";
    }

    private RenderFragment PersonRow(TroopPerson tp) => __builder =>
    {
        var sgp = _scoutGroupPersonLookup.GetValueOrDefault(tp.PersonId);
        bool removed = (sgp == null || sgp.NotInScoutnet);
        <tr class="@(tp.IsLeader ? "leader-row" : "")">
            <td class="sticky-col name-col">
                <a href="@($"/sk/{ScoutGroupId}/p/{tp.PersonId}")" class="person-link">
                    @tp.Person.FullName
                </a>
                @if (IsBirthdayToday(tp.Person))
                {
                    <MudIcon Icon="@Icons.Material.Filled.Cake" Size="Size.Small" Color="Color.Warning" Class="ml-1" Title="Fyller år idag!" />
                }
                @if (tp.IsLeader)
                {
                    // person is leader, mark with a chip 'L'
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-1 d-none d-sm-inline-flex">L</MudChip>
                }
                @if (removed)
                {
                    // person is marked as removed in Scoutnet, mark with a chip 'B' for borttagen
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="ml-1 d-none d-sm-inline-flex">B</MudChip>
                }
            </td>
            @if (_showExtraInfo)
            {
                <td class="age-col">@(tp.Person.Age > 0 ? $"{tp.Person.Age}" : "")</td>
                <td class="leader-col">
                    <MudCheckBox T="bool" 
                                 Value="@tp.IsLeader"
                                 ValueChanged="@((bool val) => ToggleLeaderStatus(tp, val))"
                                 Color="Color.Primary"
                                 Dense="true" />
                </td>
                <td class="patrol-col">
                    @if (_editingPatrolPersonId == tp.PersonId)
                    {
                        <div class="d-flex align-center gap-1">
                            <MudTextField @bind-Value="_editingPatrolValue" 
                                          Variant="Variant.Text" 
                                          Margin="Margin.Dense"
                                          Class="patrol-input"
                                          Placeholder="Patrull..."
                                          Immediate="true"
                                          OnKeyDown="@(async (e) => await OnPatrolKeyDown(e, tp.PersonId))"
                                          AutoFocus="true" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check" 
                                           Size="Size.Small" 
                                           Color="Color.Success"
                                           OnClick="@(() => SavePatrol(tp.PersonId))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                           Size="Size.Small" 
                                           Color="Color.Error"
                                           OnClick="CancelPatrolEdit" />
                        </div>
                    }
                    else
                    {
                        <div class="patrol-display" @onclick="@(() => StartPatrolEdit(tp))">
                            @if (string.IsNullOrEmpty(tp.Patrol))
                            {
                                <span class="patrol-placeholder">Klicka för att ange...</span>
                            }
                            else
                            {
                                @tp.Patrol
                            }
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="patrol-edit-icon ml-1" />
                        </div>
                    }
                </td>
                <td class="action-col">
                    @if (_pendingRemovePersonId == tp.PersonId)
                    {
                        <div class="d-flex align-center gap-1">
                            <MudTooltip Text="Bekräfta borttagning">
                                <MudIconButton Icon="@Icons.Material.Filled.Check" 
                                               Size="Size.Small" 
                                               Color="Color.Error"
                                               OnClick="@(() => RemoveMemberFromTroop(tp))" />
                            </MudTooltip>
                            <MudTooltip Text="Avbryt">
                                <MudIconButton Icon="@Icons.Material.Filled.Close" 
                                               Size="Size.Small" 
                                               Color="Color.Default"
                                               OnClick="CancelRemove" />
                            </MudTooltip>
                        </div>
                    }
                    else
                    {
                        <MudTooltip Text="Ta bort från avdelningen">
                            <MudIconButton Icon="@Icons.Material.Filled.PersonRemove" 
                                           Size="Size.Small" 
                                           Color="Color.Error"
                                           OnClick="@(() => RemoveMemberFromTroop(tp))" />
                        </MudTooltip>
                    }
                </td>
            }
            @foreach (var meeting in _meetings)
            {
                <td class="check-col">
                    <MudCheckBox T="bool" 
                                 Value="@IsAttending(tp.PersonId, meeting.Id)"
                                 ValueChanged="@((bool val) => OnAttendanceChanged(tp.PersonId, meeting.Id, val))"
                                 Color="Color.Success"
                                 Dense="true"
                                 Disabled="@(_troop?.IsLocked ?? false)" />
                </td>
            }
            @if (_meetings.Count > 0)
            {
                <td class="sum-col">
                    <strong>@GetAttendanceCount(tp.PersonId)</strong>
                </td>
            }
        </tr>
    };
}
