    protected override async Task OnInitializedAsync()
    {
        // Check access immediately using URL parameter
        _hasAccess = CurrentUserService.HasGroupAccess(ScoutGroupId);
        
        if (!_hasAccess)
        {
            _loading = false;
            _breadcrumbs = new List<BreadcrumbItem>
            {
                new("Scoutkårer", href: "/sk"),
                new("Ingen behörighet", href: null, disabled: true)
            };
            _initialized = true;
            return;
        }

        // Register handlers with the state service
        _attendanceHandlerId = StateService.RegisterAttendanceHandler(HandleAttendanceChangedAsync);
        _patrolHandlerId = StateService.RegisterPatrolHandler(HandlePatrolChangedAsync);
        _meetingHandlerId = StateService.RegisterMeetingHandler(HandleMeetingChangedAsync);
        _memberHandlerId = StateService.RegisterMemberHandler(HandleMemberChangedAsync);
        
        // Load data once during initialization
        await LoadData();
        
        _initialized = true;
    }

    private Task HandleAttendanceChangedAsync(int troopId, int personId, int meetingId, bool attending, string sourceInstanceId)
    {
        if (_disposed || sourceInstanceId == _instanceId || _troop == null || troopId != _troop.Id) return Task.CompletedTask;
        
        try
        {
            var key = (personId, meetingId);
            _attendance[key] = attending;
            _originalAttendance[key] = attending;
            _ = TryInvokeStateHasChangedAsync();
        }
        catch { }
        
        return Task.CompletedTask;
    }

    private Task HandlePatrolChangedAsync(int troopId, int personId, string? patrol, string sourceInstanceId)
    {
        if (_disposed || sourceInstanceId == _instanceId || _troop == null || troopId != _troop.Id) return Task.CompletedTask;
        
        try
        {
            var troopPerson = _troopPersons.FirstOrDefault(tp => tp.PersonId == personId);
            if (troopPerson != null)
            {
                troopPerson.Patrol = patrol;
                _ = TryInvokeStateHasChangedAsync();
            }
        }
        catch { }
        
        return Task.CompletedTask;
    }

    private Task HandleMeetingChangedAsync(int troopId, int meetingId, MeetingChangeType changeType, string sourceInstanceId)
    {
        if (_disposed || sourceInstanceId == _instanceId || _troop == null || troopId != _troop.Id) return Task.CompletedTask;

        // Reload data when meetings change - fire and forget
        _ = ReloadDataAsync();
        return Task.CompletedTask;
    }

    private Task HandleMemberChangedAsync(int troopId, int personId, TroopMemberChangeType changeType, string sourceInstanceId)
    {
        if (_disposed || sourceInstanceId == _instanceId || _troop == null || troopId != _troop.Id) return Task.CompletedTask;

        // Reload data when members change - fire and forget
        _ = ReloadDataAsync();
        return Task.CompletedTask;
    }

    private async Task ReloadDataAsync()
    {
        try
        {
            await LoadData();
            await TryInvokeStateHasChangedAsync();
        }
        catch { }
    }

    protected override async Task OnParametersSetAsync()
    {
        // Skip if not yet initialized (OnInitializedAsync will handle the first load)
        if (!_initialized) return;
        
        // Only reload if parameters actually changed
        if (_lastLoadedScoutGroupId != ScoutGroupId || 
            _lastLoadedSemesterId != SemesterId || 
            _lastLoadedTroopScoutnetId != TroopScoutnetId)
        {
            await LoadData();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed) return;
        
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsyncIgnoreErrors("eval", """
                if (!window._beforeUnloadRegistered) {
                    window._beforeUnloadRegistered = true;
                    window.addEventListener('beforeunload', function(e) {
                        if (window.hasUnsavedChanges) { e.preventDefault(); e.returnValue = 'Du har osparade ändringar.'; return e.returnValue; }
                    });
                }
            """);
        }
        await JSRuntime.InvokeVoidAsyncIgnoreErrors("eval", $"window.hasUnsavedChanges = {(_saveStatus == SaveStatus.Unsaved).ToString().ToLower()};");
    }

    private async Task<bool> TryInvokeJsAsync(string identifier, params object?[] args)
    {
        if (_disposed) return false;
        try
        {
            await JSRuntime.InvokeVoidAsync(identifier, args);
            return true;
        }
        catch (JSDisconnectedException) { return false; }
        catch (ObjectDisposedException) { return false; }
        catch (TaskCanceledException) { return false; }
        catch (InvalidOperationException) { return false; } // Can occur when circuit is disposed
    }

    /// <summary>
    /// Safely invoke StateHasChanged, handling disconnection scenarios.
    /// </summary>
    private async Task TryInvokeStateHasChangedAsync()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (JSDisconnectedException) { /* Circuit disconnected, ignore */ }
        catch (ObjectDisposedException) { /* Component disposed, ignore */ }
        catch (TaskCanceledException) { /* Operation canceled, ignore */ }
        catch (InvalidOperationException) { /* Circuit may be disposed, ignore */ }
    }

    private async Task LoadData()
    {
        _loading = true;
        
        // Update tracking variables (for navigation/parameter changes)
        _lastLoadedScoutGroupId = ScoutGroupId;
        _lastLoadedSemesterId = SemesterId;
        _lastLoadedTroopScoutnetId = TroopScoutnetId;

        try
        {
            // Load data sequentially - DbContext is not thread-safe
            _scoutGroup = await ScoutGroupRepository.GetByIdAsync(ScoutGroupId);
            _semester = await SemesterRepository.GetByIdAsync(SemesterId);
            _troop = await TroopRepository.GetWithMembersByScoutnetIdAsync(TroopScoutnetId, SemesterId);
            
            if (_scoutGroup != null && _semester != null && _troop != null)
            {
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new("Scoutkårer", href: "/sk"),
                    new(_scoutGroup.Name, href: $"/sk/{ScoutGroupId}"),
                    new(_semester.DisplayName, href: $"/sk/{ScoutGroupId}/t/{SemesterId}"),
                    new(_troop.Name, href: null, disabled: true)
                };

                _troopPersons = _troop.TroopPersons
                    .OrderByDescending(tp => tp.IsLeader)
                    // Order by FirstName then LastName
                    .ThenBy(tp => tp.Person.FirstName)
                    .ThenBy(tp => tp.Person.LastName)
                    .ToList();

                // Build set of current member IDs for quick lookup
                _troopPersonIds = _troopPersons.Select(tp => tp.PersonId).ToHashSet();

                // Set new-meeting defaults from troop settings
                _newMeetingDuration = _troop.DefaultDurationMinutes;
                _newMeetingTime = _troop.DefaultStartTime.ToTimeSpan();
                _newMeetingLocation = _troop.DefaultMeetingLocation;

                // Load all meetings with attendance in a SINGLE query instead of N+1 queries
                var meetingsWithAttendance = await MeetingRepository.GetByTroopWithAttendanceAsync(_troop.Id);
                _meetings = meetingsWithAttendance.ToList();

                // Build attendance dictionary from the already-loaded data
                _attendance.Clear();
                foreach (var meeting in _meetings)
                {
                    foreach (var attendance in meeting.Attendances)
                    {
                        _attendance[(attendance.PersonId, meeting.Id)] = true;
                    }
                }
                
                _originalAttendance = new Dictionary<(int, int), bool>(_attendance);
                _pendingChanges.Clear();
                _saveStatus = SaveStatus.Saved;

                _scoutGroupPersonLookup = _troop.ScoutGroup.ScoutGroupPersons
                    .ToDictionary(sgp => sgp.PersonId);

                // Load badge assignments
                _troopBadges = (await BadgeService.GetTroopBadgesAsync(_troop.Id)).ToList();
                var allGroupBadges = await BadgeService.GetBadgesForGroupAsync(ScoutGroupId);
                var assignedIds = _troopBadges.Select(b => b.Id).ToHashSet();
                _availableBadges = allGroupBadges.Where(b => !assignedIds.Contains(b.Id)).ToList();
            }
        }
        finally { _loading = false; }
    }

