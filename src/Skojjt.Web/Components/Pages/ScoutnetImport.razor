@page "/sk/{ScoutGroupId:int}/import"
@using Microsoft.AspNetCore.Authorization
@using Skojjt.Core.Entities
@using Skojjt.Core.Interfaces
@using Skojjt.Infrastructure.Scoutnet
@attribute [Authorize]
@rendermode InteractiveServer
@inject IScoutGroupRepository ScoutGroupRepository
@inject ISemesterRepository SemesterRepository
@inject IScoutnetImportService ImportService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Scoutnet Import - @(_scoutGroup?.Name ?? "Scoutkår") - Skojjt</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_scoutGroup == null)
    {
        <MudAlert Severity="Severity.Error">Scoutkåren kunde inte hittas.</MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-2">Scoutnet Import</MudText>
        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">@_scoutGroup.Name</MudText>

        <MudGrid>
            @* Import Configuration *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.CloudDownload" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Importinställningar</MudText>
                    </div>

                    @if (string.IsNullOrEmpty(_scoutGroup.ApiKeyAllMembers))
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-4">
                            <MudText>
                                API-nyckel för medlemslistan är inte konfigurerad.
                                <MudLink Href="@($"/sk/{ScoutGroupId}/settings")">Gå till inställningar</MudLink> för att lägga till den.
                            </MudText>
                        </MudAlert>
                    }
                    else
                    {
                        <MudStack Spacing="3">
                            <MudSelect T="int" 
                                       @bind-Value="_selectedSemesterId" 
                                       Label="Termin"
                                       Variant="Variant.Outlined"
                                       HelperText="Välj vilken termin som ska importeras till"
                                       Disabled="_isImporting">
                                @foreach (var semester in _availableSemesters)
                                {
                                    <MudSelectItem Value="@semester.Id">@semester.DisplayName</MudSelectItem>
                                }
                            </MudSelect>

                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                <MudText Typo="Typo.body2">
                                    Importen hämtar alla medlemmar från Scoutnet och synkroniserar med databasen.
                                    Nya medlemmar läggs till, befintliga uppdateras, och medlemmar som saknas markeras som borttagna.
                                </MudText>
                            </MudAlert>

                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.CloudDownload"
                                       OnClick="StartImport"
                                       Disabled="@(_isImporting || string.IsNullOrEmpty(_scoutGroup.ApiKeyAllMembers))"
                                       FullWidth="true"
                                       Size="Size.Large">
                                @if (_isImporting)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Importerar...</span>
                                }
                                else
                                {
                                    <span>Starta import</span>
                                }
                            </MudButton>
                        </MudStack>
                    }
                </MudPaper>
            </MudItem>

            @* Import Status *@
            <MudItem xs="12" md="6">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Assessment" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Importstatus</MudText>
                    </div>

                    @if (_importResult != null)
                    {
                        @if (_importResult.Success)
                        {
                            <MudAlert Severity="Severity.Success" Class="mb-4">
                                Import slutförd på @_importResult.Duration.TotalSeconds.ToString("F1") sekunder
                            </MudAlert>

                            <MudSimpleTable Dense="true" Striped="true" Class="mb-4">
                                <tbody>
                                    <tr>
                                        <td><MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Small" Class="mr-2" /> Nya personer</td>
                                        <td class="text-right"><strong>@_importResult.PersonsCreated</strong></td>
                                    </tr>
                                    <tr>
                                        <td><MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="mr-2" /> Uppdaterade personer</td>
                                        <td class="text-right"><strong>@_importResult.PersonsUpdated</strong></td>
                                    </tr>
                                    <tr>
                                        <td><MudIcon Icon="@Icons.Material.Filled.PersonRemove" Size="Size.Small" Class="mr-2" /> Borttagna personer</td>
                                        <td class="text-right"><strong>@_importResult.PersonsRemoved</strong></td>
                                    </tr>
                                    <tr>
                                        <td><MudIcon Icon="@Icons.Material.Filled.Group" Size="Size.Small" Class="mr-2" /> Nya avdelningar</td>
                                        <td class="text-right"><strong>@_importResult.TroopsProcessed</strong></td>
                                    </tr>
                                    <tr>
                                        <td><MudIcon Icon="@Icons.Material.Filled.GroupAdd" Size="Size.Small" Class="mr-2" /> Nya avdelningsmedlemskap</td>
                                        <td class="text-right"><strong>@_importResult.TroopMembershipsCreated</strong></td>
                                    </tr>
                                    <tr>
                                        <td><MudIcon Icon="@Icons.Material.Filled.GroupRemove" Size="Size.Small" Class="mr-2" /> Borttagna avdelningsmedlemskap</td>
                                        <td class="text-right"><strong>@_importResult.TroopMembershipsRemoved</strong></td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Error" Class="mb-4">
                                Import misslyckades: @_importResult.ErrorMessage
                            </MudAlert>
                        }
                    }
                    else if (!_isImporting)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            Ingen import har körts ännu. Klicka på "Starta import" för att börja.
                        </MudAlert>
                    }
                </MudPaper>
            </MudItem>

            @* Progress Log *@
            <MudItem xs="12">
                <MudPaper Elevation="2" Class="pa-4">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Terminal" Class="mr-2" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Importlogg</MudText>
                        </div>
                        @if (_logMessages.Count > 0)
                        {
                            <MudButton Variant="Variant.Text" 
                                       Size="Size.Small" 
                                       OnClick="ClearLog"
                                       StartIcon="@Icons.Material.Filled.Delete">
                                Rensa logg
                            </MudButton>
                        }
                    </div>

                    <MudPaper Elevation="0" 
                              Style="background-color: #1e1e1e; color: #d4d4d4; font-family: 'Consolas', 'Monaco', monospace; font-size: 12px; max-height: 400px; overflow-y: auto;"
                              Class="pa-3">
                        @if (_logMessages.Count == 0)
                        {
                            <div style="color: #6a9955;">// Importloggen visas här när importen startar</div>
                        }
                        else
                        {
                            @foreach (var (message, timestamp, severity) in _logMessages)
                            {
                                <div style="color: @GetLogColor(severity)">
                                    <span style="color: #6a9955;">[@timestamp.ToString("HH:mm:ss")]</span> @message
                                </div>
                            }
                        }
                    </MudPaper>
                </MudPaper>
            </MudItem>

            @* Detailed Log Messages *@
            @if (_importResult?.LogMessages.Count > 0)
            {
                <MudItem xs="12">
                    <MudExpansionPanels>
                        <MudExpansionPanel Text="@($"Detaljerade ändringar ({_importResult.LogMessages.Count} st)")">
                            <MudList T="string" Dense="true">
                                @foreach (var message in _importResult.LogMessages.Take(100))
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight">
                                        @message
                                    </MudListItem>
                                }
                                @if (_importResult.LogMessages.Count > 100)
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.MoreHoriz">
                                        ... och @(_importResult.LogMessages.Count - 100) till
                                    </MudListItem>
                                }
                            </MudList>
                        </MudExpansionPanel>
                    </MudExpansionPanels>
                </MudItem>
            }

            @* Details: Created Persons and Troops *@
            @if (_importResult?.Success == true && (_importResult.CreatedPersons.Count > 0 || _importResult.CreatedTroops.Count > 0 || _importResult.RemovedPersons.Count > 0 || _importResult.CreatedScoutGroups.Count > 0))
            {
                <MudItem xs="12">
                    <MudExpansionPanels MultiExpansion="true">
                        @if (_importResult.CreatedScoutGroups.Count > 0)
                        {
                            <MudExpansionPanel Text="@($"Nya scoutkårer ({_importResult.CreatedScoutGroups.Count} st)")" 
                                               Icon="@Icons.Material.Filled.Business">
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                    Följande scoutkårer skapades automatiskt under importen.
                                </MudAlert>
                                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                                    <thead>
                                        <tr>
                                            <th>Namn</th>
                                            <th>ID</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var scoutGroup in _importResult.CreatedScoutGroups.OrderBy(sg => sg.Name))
                                        {
                                            <tr>
                                                <td>
                                                    <MudLink Href="@($"/sk/{scoutGroup.Id}")">
                                                        @scoutGroup.Name
                                                    </MudLink>
                                                </td>
                                                <td>@scoutGroup.Id</td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudExpansionPanel>
                        }

                        @if (_importResult.CreatedTroops.Count > 0)
                        {
                            <MudExpansionPanel Text="@($"Nya avdelningar ({_importResult.CreatedTroops.Count} st)")" 
                                               Icon="@Icons.Material.Filled.Group">
                                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                                    <thead>
                                        <tr>
                                            <th>Namn</th>
                                            <th class="text-right">Medlemmar</th>
                                            <th class="text-right">Ledare</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var troop in _importResult.CreatedTroops.OrderBy(t => t.Name))
                                        {
                                            <tr>
                                                <td>@troop.Name</td>
                                                <td class="text-right">@troop.MemberCount</td>
                                                <td class="text-right">@troop.LeaderCount</td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudExpansionPanel>
                        }

                        @if (_importResult.CreatedPersons.Count > 0)
                        {
                            <MudExpansionPanel Text="@($"Nya personer ({_importResult.CreatedPersons.Count} st)")" 
                                               Icon="@Icons.Material.Filled.PersonAdd">
                                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                                    <thead>
                                        <tr>
                                            <th>Namn</th>
                                            <th>Avdelning</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var person in _importResult.CreatedPersons.OrderBy(p => p.FullName).Take(100))
                                        {
                                            <tr>
                                                <td>
                                                    <MudLink Href="@($"/sk/{ScoutGroupId}/p/{person.Id}")">
                                                        @person.FullName
                                                    </MudLink>
                                                </td>
                                                <td>@(person.TroopName ?? "-")</td>
                                            </tr>
                                        }
                                        @if (_importResult.CreatedPersons.Count > 100)
                                        {
                                            <tr>
                                                <td colspan="2" class="text-center">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        ... och @(_importResult.CreatedPersons.Count - 100) till
                                                    </MudText>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudExpansionPanel>
                        }

                        @if (_importResult.RemovedPersons.Count > 0)
                        {
                            <MudExpansionPanel Text="@($"Borttagna personer ({_importResult.RemovedPersons.Count} st)")" 
                                               Icon="@Icons.Material.Filled.PersonRemove">
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                    Dessa personer finns inte längre i Scoutnet och har markerats som borttagna.
                                </MudAlert>
                                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                                    <thead>
                                        <tr>
                                            <th>Namn</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var person in _importResult.RemovedPersons.OrderBy(p => p.FullName).Take(100))
                                        {
                                            <tr>
                                                <td>
                                                    <MudLink Href="@($"/sk/{ScoutGroupId}/p/{person.Id}")">
                                                        @person.FullName
                                                    </MudLink>
                                                </td>
                                            </tr>
                                        }
                                        @if (_importResult.RemovedPersons.Count > 100)
                                        {
                                            <tr>
                                                <td class="text-center">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        ... och @(_importResult.RemovedPersons.Count - 100) till
                                                    </MudText>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudExpansionPanel>
                        }
                    </MudExpansionPanels>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    [Parameter]
    public int ScoutGroupId { get; set; }

    private ScoutGroup? _scoutGroup;
    private List<Semester> _availableSemesters = new();
    private int _selectedSemesterId;
    private bool _loading = true;
    private bool _initialized;
    private int _lastLoadedScoutGroupId;
    private bool _isImporting = false;
    private ScoutnetImportResult? _importResult;
    private List<(string Message, DateTime Timestamp, LogSeverity Severity)> _logMessages = new();
    private List<BreadcrumbItem> _breadcrumbs = new();
    private CancellationTokenSource? _importCts;

    private enum LogSeverity { Info, Success, Warning, Error }

    protected override async Task OnInitializedAsync()
    {
        _lastLoadedScoutGroupId = ScoutGroupId;
        await LoadData();
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized) return;

        if (_lastLoadedScoutGroupId != ScoutGroupId)
        {
            _lastLoadedScoutGroupId = ScoutGroupId;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _scoutGroup = await ScoutGroupRepository.GetByIdAsync(ScoutGroupId);
            
            if (_scoutGroup != null)
            {
                // Get current semester and create if needed
                var currentSemester = await SemesterRepository.GetOrCreateCurrentSemesterAsync();
                
                // Get all available semesters
                var semesters = await SemesterRepository.GetAllOrderedAsync();
                _availableSemesters = semesters.ToList();
                
                // Make sure current semester is in the list
                if (!_availableSemesters.Any(s => s.Id == currentSemester.Id))
                {
                    _availableSemesters.Insert(0, currentSemester);
                }
                
                _selectedSemesterId = currentSemester.Id;
                
                _breadcrumbs = new List<BreadcrumbItem>
                {
                    new BreadcrumbItem("Scoutkårer", href: "/sk"),
                    new BreadcrumbItem(_scoutGroup.Name, href: $"/sk/{ScoutGroupId}"),
                    new BreadcrumbItem("Scoutnet Import", href: null, disabled: true)
                };
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task StartImport()
    {
        if (_scoutGroup == null || string.IsNullOrEmpty(_scoutGroup.ApiKeyAllMembers))
            return;

        _isImporting = true;
        _importResult = null;
        _logMessages.Clear();
        _importCts = new CancellationTokenSource();

        try
        {
            var selectedSemester = _availableSemesters.FirstOrDefault(s => s.Id == _selectedSemesterId);
            AddLog($"Startar import för {_scoutGroup.Name}, termin {selectedSemester?.DisplayName ?? _selectedSemesterId.ToString()}", LogSeverity.Info);
            
            var progress = new Progress<string>(message =>
            {
                InvokeAsync(() =>
                {
                    var severity = message.Contains("error", StringComparison.OrdinalIgnoreCase) ? LogSeverity.Error :
                                   message.Contains("warning", StringComparison.OrdinalIgnoreCase) ? LogSeverity.Warning :
                                   message.Contains("completed", StringComparison.OrdinalIgnoreCase) ? LogSeverity.Success :
                                   LogSeverity.Info;
                    AddLog(message, severity);
                    StateHasChanged();
                });
            });

            _importResult = await ImportService.ImportMembersAsync(
                ScoutGroupId,
                _selectedSemesterId,
                progress,
                _importCts.Token);

            if (_importResult.Success)
            {
                AddLog($"Import slutförd! {_importResult.PersonsCreated} nya, {_importResult.PersonsUpdated} uppdaterade, {_importResult.PersonsRemoved} borttagna", LogSeverity.Success);
                Snackbar.Add($"Import slutförd för {_scoutGroup.Name}", Severity.Success);
            }
            else
            {
                AddLog($"Import misslyckades: {_importResult.ErrorMessage}", LogSeverity.Error);
                Snackbar.Add($"Import misslyckades: {_importResult.ErrorMessage}", Severity.Error);
            }
        }
        catch (OperationCanceledException)
        {
            AddLog("Import avbruten av användaren", LogSeverity.Warning);
            Snackbar.Add("Import avbruten", Severity.Warning);
        }
        catch (Exception ex)
        {
            AddLog($"Ett oväntat fel uppstod: {ex.Message}", LogSeverity.Error);
            Snackbar.Add($"Fel: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isImporting = false;
            _importCts?.Dispose();
            _importCts = null;
        }
    }

    private void AddLog(string message, LogSeverity severity)
    {
        _logMessages.Add((message, DateTime.Now, severity));
    }

    private void ClearLog()
    {
        _logMessages.Clear();
    }

    private static string GetLogColor(LogSeverity severity) => severity switch
    {
        LogSeverity.Success => "#4ec9b0",
        LogSeverity.Warning => "#dcdcaa",
        LogSeverity.Error => "#f14c4c",
        _ => "#d4d4d4"
    };

    public void Dispose()
    {
        _importCts?.Cancel();
        _importCts?.Dispose();
    }
}
