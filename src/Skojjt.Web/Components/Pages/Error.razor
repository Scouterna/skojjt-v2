@page "/Error"
@using System.Diagnostics

<PageTitle>Fel - Skojjt</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-center align-center" Style="min-height: 60vh;">
    <MudStack AlignItems="AlignItems.Center" Spacing="4" Class="my-8">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" Color="Color.Error" />
        <MudText Typo="Typo.h4" Align="Align.Center">Ett oväntat fel uppstod</MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
            Något gick fel. Försök igen eller gå tillbaka till startsidan.
        </MudText>
        @if (ShowRequestId)
        {
            <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
                Request ID: @RequestId
            </MudText>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/"
                   StartIcon="@Icons.Material.Filled.Home">
            Tillbaka till startsidan
        </MudButton>
    </MudStack>
</MudContainer>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
