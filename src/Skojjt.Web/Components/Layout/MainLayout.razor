@inherits LayoutComponentBase
@using Skojjt.Core.Authentication
@inject ICurrentUserService CurrentUserService
@inject IAdminModeService AdminModeService

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudLink Href="/" Underline="Underline.None" Class="d-flex align-center ml-2">
            <MudImage Src="/img/icon.png" Alt="Skojjt" Width="32" Height="32" Class="mr-2" />
            <MudText Typo="Typo.h5" Color="Color.Inherit">Skojjt</MudText>
        </MudLink>
        <MudSpacer />
        @if (AdminModeService.IsAdminModeActive)
        {
            <MudChip T="string"
                     Color="Color.Warning"
                     Size="Size.Small"
                     Icon="@Icons.Material.Filled.Shield"
                     OnClick="ToggleAdminMode"
                     Class="mr-2 cursor-pointer">
                Admin
            </MudChip>
        }
        <ThemeToggle />
        <AuthorizeView>
            <Authorized>
                @if (CurrentUserService.IsAdmin)
                {
                    <MudTooltip Text="@(AdminModeService.IsAdminModeActive ? "Stäng av adminläge" : "Aktivera adminläge")">
                        <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings"
                                       Color="@(AdminModeService.IsAdminModeActive ? Color.Warning : Color.Inherit)"
                                       OnClick="ToggleAdminMode" />
                    </MudTooltip>
                }
                <MudTooltip Text="Min profil">
                    <MudLink Href="/me" Color="Color.Inherit" Underline="Underline.None" Class="d-flex align-center ml-2 mr-2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Medium" Class="mr-1" />
                        <MudText Typo="Typo.body2" Color="Color.Inherit" Class="d-none d-sm-inline">@context.User.Identity?.Name</MudText>
                    </MudLink>
                </MudTooltip>
                <MudTooltip Text="Logga ut">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" Href="/auth/logout" />
                </MudTooltip>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Href="/login" StartIcon="@Icons.Material.Filled.Login">Logga in</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleAdminMode()
    {
        AdminModeService.SetAdminMode(!AdminModeService.IsAdminModeActive);
    }
}
