@inherits LayoutComponentBase
@using Skojjt.Core.Authentication
@inject ICurrentUserService CurrentUserService
@inject IAdminModeService AdminModeService

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h5" Class="ml-3">Skojjt</MudText>
        <MudSpacer />
        <ThemeToggle />
        <AuthorizeView>
            <Authorized>
                @if (CurrentUserService.IsAdmin)
                {
                    <MudTooltip Text="@(AdminModeService.IsAdminModeActive ? "Adminläge aktivt – klicka för att stänga av" : "Adminläge av – klicka för att aktivera")">
                        <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings"
                                       Color="@(AdminModeService.IsAdminModeActive ? Color.Warning : Color.Inherit)"
                                       OnClick="ToggleAdminMode" />
                    </MudTooltip>
                }
                <MudLink Href="/me" Color="Color.Inherit" Underline="Underline.None" Class="mr-4 d-none d-sm-block">@context.User.Identity?.Name</MudLink>
                <MudTooltip Text="Logga ut">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" Href="/auth/logout" />
                </MudTooltip>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Href="/login">Logga in</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>
    
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleAdminMode()
    {
        AdminModeService.SetAdminMode(!AdminModeService.IsAdminModeActive);
    }
}
