# Auto-detect text files and normalize to LF in the repo
* text=auto eol=lf

# Explicitly mark file types as text with LF endings
*.cs        text eol=lf
*.razor     text eol=lf
*.cshtml    text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.html      text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.editorconfig text eol=lf

# Binary files — don't touch
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.zip       binary
